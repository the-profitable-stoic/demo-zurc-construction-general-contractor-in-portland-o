---
import { siteConfig } from "../../lib/site-config";

const { name: businessName, phone, category, city, state } = siteConfig.business;

// Slug-to-display-name mapping

const ACRONYMS = new Set(["hvac", "ac", "bbq", "rv", "atv", "suv"]);
function nicheDisplayName(input: string): string {
  return input.split(/[\s-]+/).map(word => {
    if (ACRONYMS.has(word.toLowerCase())) return word.toUpperCase();
    return word.charAt(0).toUpperCase() + word.slice(1);
  }).join(" ");
}
const categoryDisplay = nicheDisplayName(category);
const brandDisplay = nicheDisplayName(businessName);

// Professional adjective form for footer text
const NICHE_ADJECTIVES: Record<string, string> = {
  "dentist": "dental", "chiropractor": "chiropractic", "optometrist": "optometry",
  "veterinarian": "veterinary", "physical-therapy": "physical therapy",
};
const categoryAdj = NICHE_ADJECTIVES[category] || categoryDisplay.toLowerCase();
// Avoid "tree service services" redundancy
const categoryClean = categoryAdj.replace(/ service$/i, "").replace(/ services$/i, "");
const services = (siteConfig.content.services || []).slice(0, 6);
const serviceAreas = (siteConfig.content.serviceAreas || []).slice(0, 8);
const currentYear = new Date().getFullYear();

const companyLinks = [
  { label: "About", href: "/about/" },
  { label: "Reviews", href: "/reviews/" },
  { label: "Gallery", href: "/gallery/" },
  { label: "Contact", href: "/contact/" },
  { label: "Privacy Policy", href: "/privacy/" },
  { label: "Terms of Service", href: "/terms/" },
];
---

<footer class="site-footer" role="contentinfo" aria-label="Site footer">
  <div class="container">
    <div class="footer-grid animate-fade-up">
      <!-- Column 1: Brand -->
      <div class="footer-col footer-brand">
        <a href="/" class="footer-logo" aria-label={`${brandDisplay} home`}>
          {brandDisplay}
        </a>
        <p class="footer-tagline">
          Trusted {categoryAdj} professionals serving {city}, {state} and the surrounding areas.
          Quality work, honest pricing, guaranteed satisfaction.
        </p>
        <a href={`tel:${phone}`} class="footer-phone" aria-label={`Call us at ${phone}`}>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {phone}
        </a>
      </div>

      <!-- Column 2: Services -->
      <div class="footer-col">
        <h3 class="footer-heading">Services</h3>
        <ul class="footer-links" role="list">
          {services.map((s: any) => (
            <li><a href={`/services/${s.slug}/`}>{s.name}</a></li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Service Areas -->
      <div class="footer-col">
        <h3 class="footer-heading">Service Areas</h3>
        <ul class="footer-links" role="list">
          {serviceAreas.map((area: any) => (
            <li><a href={`/service-areas/${area.slug}/`}>{area.city}</a></li>
          ))}
        </ul>
      </div>

      <!-- Column 4: Company -->
      <div class="footer-col">
        <h3 class="footer-heading">Company</h3>
        <ul class="footer-links" role="list">
          {companyLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copyright">
        &copy; {currentYear} {brandDisplay}. All rights reserved.
      </p>
      <span class="footer-badge" aria-label="Licensed and insured">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Licensed &amp; Insured
      </span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-primary-dark);
    color: var(--color-text-on-dark);
    padding: 4rem 0 0;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* ---- Brand Column ---- */
  .footer-brand {
    max-width: 340px;
  }

  .footer-logo {
    display: inline-block;
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: 1.45rem;
    color: var(--color-text-on-dark);
    text-decoration: none;
    margin-bottom: 0.85rem;
    line-height: 1.2;
  }

  .footer-tagline {
    font-family: var(--font-body);
    font-size: 0.925rem;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.7;
    margin: 0 0 1.25rem;
  }

  .footer-phone {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-phone:hover {
    color: var(--color-primary-light);
  }

  /* ---- Link Columns ---- */
  .footer-heading {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.7);
    margin: 0 0 1.15rem;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .footer-links a {
    font-family: var(--font-body);
    font-size: 0.925rem;
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: color 0.2s ease;
    line-height: 1.4;
  }

  .footer-links a:hover {
    color: var(--color-text-on-dark);
  }

  /* ---- Bottom Bar ---- */
  .footer-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 1.75rem 0;
    text-align: center;
  }

  .footer-copyright {
    font-family: var(--font-body);
    font-size: 0.825rem;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .footer-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.75);
    background-color: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-button);
    padding: 0.4rem 0.9rem;
  }

  /* ---- Responsive ---- */
  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }

    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  @media (min-width: 1024px) {
    .site-footer {
      padding-top: 5rem;
    }

    .footer-grid {
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
      gap: 3rem;
      padding-bottom: 4rem;
    }
  }
</style>
