---
import { siteConfig } from "../../lib/site-config";

const { gallery = [] } = siteConfig.images || {};
const { name: businessName, category } = siteConfig.business;
---

<section class="gallery-section section-padding" aria-labelledby="gallery-heading">
  <div class="container">
    <div class="gallery-header animate-fade-up">
      <h2 id="gallery-heading" class="gallery-title">Our Work</h2>
      <p class="gallery-intro">
        Browse our portfolio of recent {category.toLowerCase()} projects. Every job reflects
        our commitment to quality craftsmanship and attention to detail.
      </p>
    </div>

    {gallery.length > 0 ? (
      <div class="masonry-grid animate-fade-in">
        {gallery.map((src: string, i: number) => (
          <figure class="masonry-item animate-scale-in" style={`animation-delay: ${i * 80}ms`}>
            <img
              src={src}
              alt={`${category} project ${i + 1} by ${businessName}`}
              loading="lazy"
              width="600"
              height="400"
              decoding="async"
            />
          </figure>
        ))}
      </div>
    ) : (
      <p class="gallery-empty">Project photos coming soon.</p>
    )}
  </div>
</section>

<style>
  .gallery-section {
    background-color: var(--color-background);
  }

  .gallery-header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 3rem;
  }

  .gallery-title {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: clamp(2rem, 4vw, 3rem);
    color: inherit;
    margin: 0 0 1rem;
    line-height: 1.15;
  }

  .gallery-intro {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.8vw, 1.175rem);
    color: inherit; opacity: 0.7;
    line-height: 1.7;
    margin: 0;
  }

  /* Masonry via CSS columns */
  .masonry-grid {
    column-count: 1;
    column-gap: 1rem;
  }

  .masonry-item {
    break-inside: avoid;
    margin: 0 0 1rem;
    padding: 0;
    border-radius: var(--radius-card);
    overflow: hidden;
    background-color: var(--color-surface);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
    display: inline-block;
    width: 100%;
  }

  .masonry-item:hover {
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.14);
    transform: translateY(-4px);
  }

  .masonry-item img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: var(--radius-card);
  }

  .gallery-empty {
    text-align: center;
    font-family: var(--font-body);
    color: inherit; opacity: 0.7;
    font-size: 1.1rem;
    padding: 4rem 0;
  }

  /* Tablet: 2 columns */
  @media (min-width: 640px) {
    .masonry-grid {
      column-count: 2;
      column-gap: 1.25rem;
    }

    .masonry-item {
      margin-bottom: 1.25rem;
    }
  }

  /* Desktop: 3 columns */
  @media (min-width: 1024px) {
    .masonry-grid {
      column-count: 3;
      column-gap: 1.5rem;
    }

    .masonry-item {
      margin-bottom: 1.5rem;
    }

    .gallery-header {
      margin-bottom: 4rem;
    }
  }
</style>
