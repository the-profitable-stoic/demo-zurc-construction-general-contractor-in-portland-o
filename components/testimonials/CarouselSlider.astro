---
import { siteConfig } from '../../lib/site-config';

const reviews = siteConfig.content.reviews;
---

<section class="carousel-testimonials section-padding">
  <div class="container">
    <div class="carousel-header animate-fade-up">
      <p class="carousel-label">Testimonials</p>
      <h2 class="carousel-title">What Our Clients Say</h2>
    </div>

    <div class="carousel-wrapper animate-fade-in">
      <div class="carousel-track" role="region" aria-label="Client testimonials" tabindex="0">
        {reviews.map((review, i) => (
          <article class="carousel-slide" aria-label={`Review ${i + 1} of ${reviews.length}`}>
            <div class="carousel-quote-mark" aria-hidden="true">&ldquo;</div>
            <blockquote class="carousel-text">
              <p>{review.text}</p>
            </blockquote>
            <div class="carousel-stars" aria-label={`${review.rating} out of 5 stars`}>
              {Array.from({ length: 5 }).map((_, s) => (
                <svg
                  class={`carousel-star ${s < review.rating ? 'carousel-star--filled' : ''}`}
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill={s < review.rating ? 'currentColor' : 'none'}
                  stroke="currentColor"
                  stroke-width="1.5"
                  aria-hidden="true"
                >
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                </svg>
              ))}
            </div>
            <footer class="carousel-attribution">
              <cite class="carousel-name">{review.name}</cite>
              {review.service && (
                <span class="carousel-service">{review.service}</span>
              )}
            </footer>
          </article>
        ))}
      </div>

      {/* Navigation arrows */}
      <button class="carousel-arrow carousel-arrow--prev" aria-label="Previous review" type="button">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="15 18 9 12 15 6" />
        </svg>
      </button>
      <button class="carousel-arrow carousel-arrow--next" aria-label="Next review" type="button">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="9 18 15 12 9 6" />
        </svg>
      </button>

      {/* Dot indicators */}
      <div class="carousel-dots" aria-hidden="true">
        {reviews.map((_, i) => (
          <span class={`carousel-dot ${i === 0 ? 'carousel-dot--active' : ''}`} data-index={i} />
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  function initCarousel() {
    const track = document.querySelector('.carousel-track') as HTMLElement;
    const slides = track?.querySelectorAll('.carousel-slide');
    const prevBtn = document.querySelector('.carousel-arrow--prev') as HTMLButtonElement;
    const nextBtn = document.querySelector('.carousel-arrow--next') as HTMLButtonElement;
    const dots = document.querySelectorAll('.carousel-dot');
    if (!track || !slides?.length) return;

    let current = 0;
    const total = slides.length;

    function updateDots(idx: number) {
      dots.forEach((d, i) => d.classList.toggle('carousel-dot--active', i === idx));
    }

    function scrollTo(idx: number) {
      current = Math.max(0, Math.min(idx, total - 1));
      const slide = slides[current] as HTMLElement;
      track.scrollTo({ left: slide.offsetLeft, behavior: 'smooth' });
      updateDots(current);
    }

    prevBtn?.addEventListener('click', () => scrollTo(current - 1));
    nextBtn?.addEventListener('click', () => scrollTo(current + 1));

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const idx = Number((dot as HTMLElement).dataset.index);
        scrollTo(idx);
      });
    });

    // Sync dots on manual scroll/snap
    let scrollTimeout: number;
    track.addEventListener('scroll', () => {
      clearTimeout(scrollTimeout);
      scrollTimeout = window.setTimeout(() => {
        const scrollLeft = track.scrollLeft;
        const slideWidth = (slides[0] as HTMLElement).offsetWidth;
        const idx = Math.round(scrollLeft / slideWidth);
        if (idx !== current) {
          current = idx;
          updateDots(current);
        }
      }, 80);
    });
  }

  initCarousel();
  document.addEventListener('astro:after-swap', initCarousel);
</script>

<style>
  .carousel-testimonials {
    background: var(--color-background-alt);
  }

  .carousel-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .carousel-label {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 0.75rem;
  }

  .carousel-title {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: clamp(2rem, 4vw, 3rem);
    color: inherit;
    margin: 0;
    line-height: 1.15;
  }

  /* Wrapper for positioning arrows */
  .carousel-wrapper {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
  }

  /* Scroll-snap track */
  .carousel-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    -webkit-overflow-scrolling: touch;
    gap: 0;
  }

  .carousel-track::-webkit-scrollbar {
    display: none;
  }

  /* Individual slide */
  .carousel-slide {
    flex: 0 0 100%;
    scroll-snap-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem 1.5rem;
    box-sizing: border-box;
  }

  .carousel-quote-mark {
    font-family: var(--font-heading);
    font-size: clamp(4rem, 8vw, 6rem);
    line-height: 0.8;
    color: var(--color-primary);
    opacity: 0.25;
    margin-bottom: 0.5rem;
    user-select: none;
  }

  .carousel-text {
    margin: 0 0 1.5rem;
    max-width: 600px;
  }

  .carousel-text p {
    font-family: var(--font-body);
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    color: inherit;
    line-height: 1.75;
    margin: 0;
    font-style: italic;
  }

  .carousel-stars {
    display: flex;
    gap: 0.2rem;
    margin-bottom: 1.25rem;
  }

  .carousel-star {
    color: inherit; opacity: 0.7;
    opacity: 0.3;
  }

  .carousel-star--filled {
    color: var(--color-accent);
    opacity: 1;
  }

  .carousel-attribution {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  .carousel-name {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: 1.05rem;
    color: inherit;
    font-style: normal;
  }

  .carousel-service {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: inherit; opacity: 0.7;
  }

  /* Arrow buttons */
  .carousel-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 2px solid var(--color-border);
    background: var(--color-surface);
    color: inherit;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s ease, background 0.2s ease, color 0.2s ease;
    z-index: 2;
  }

  .carousel-arrow:hover {
    border-color: var(--color-primary);
    background: var(--color-primary);
    color: var(--color-text-on-dark);
  }

  .carousel-arrow--prev {
    left: -1rem;
  }

  .carousel-arrow--next {
    right: -1rem;
  }

  /* Dot indicators */
  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  .carousel-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-border);
    cursor: pointer;
    transition: background 0.25s ease, transform 0.25s ease;
  }

  .carousel-dot--active {
    background: var(--color-primary);
    transform: scale(1.25);
  }

  /* Mobile adjustments */
  @media (max-width: 640px) {
    .carousel-slide {
      padding: 1.5rem 1rem;
    }

    .carousel-arrow {
      display: none;
    }
  }

  @media (min-width: 641px) {
    .carousel-arrow--prev {
      left: -1.5rem;
    }

    .carousel-arrow--next {
      right: -1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .carousel-arrow--prev {
      left: -3rem;
    }

    .carousel-arrow--next {
      right: -3rem;
    }
  }
</style>
