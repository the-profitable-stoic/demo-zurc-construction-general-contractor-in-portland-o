---
import { siteConfig, getVariant, hasEffect } from "../../lib/site-config";

const biz = siteConfig.business;
const { ctaHeadline, ctaSubline } = siteConfig.content.homepage;
const variant = getVariant("cta");
const heroImage = siteConfig.images.hero;
const aboutImage = siteConfig.images.about;
const bgImage = heroImage || aboutImage;
const phoneHref = `tel:${biz.phone.replace(/[^+\d]/g, "")}`;
const useGradientMesh = hasEffect("gradient-mesh");
const isReversed = variant === "reversed";
---

<section
  class:list={["cta-split", { "cta-split--reversed": isReversed }]}
  aria-label="Call to action"
>
  <div class:list={["cta-split__content", { "effect-gradient-mesh": useGradientMesh }]}>
    <div class="cta-split__content-inner animate-fade-up">
      <h2 class="cta-split__headline">{ctaHeadline}</h2>
      <p class="cta-split__subline">{ctaSubline}</p>
      <div class="cta-split__actions">
        <a href={phoneHref} class="cta-split__phone" aria-label={`Call ${biz.name} at ${biz.phone}`}>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span>{biz.phone}</span>
        </a>
        <a href="/contact" class="btn-primary cta-split__btn">Get Free Estimate</a>
      </div>
    </div>
  </div>
  <div class="cta-split__image" aria-hidden="true">
    {bgImage && <img src={bgImage} alt="" class="cta-split__img" loading="lazy" />}
    <div class="cta-split__overlay"></div>
  </div>
</section>

<style>
  .cta-split {
    display: grid;
    grid-template-columns: 1fr;
    min-height: 480px;
  }

  .cta-split__content {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    background: var(--color-primary);
    color: var(--color-text-on-dark);
    position: relative;
    overflow: hidden;
  }

  .cta-split__content-inner {
    max-width: 520px;
    position: relative;
    z-index: 1;
  }

  .cta-split__headline {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 800;
    line-height: 1.15;
    margin: 0 0 1rem;
    color: var(--color-text-on-dark);
  }

  .cta-split__subline {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.7;
    margin: 0 0 2rem;
    opacity: 0.88;
  }

  .cta-split__actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cta-split__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 700;
    color: var(--color-text-on-dark);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .cta-split__phone:hover {
    opacity: 0.85;
  }

  .cta-split__btn {
    align-self: flex-start;
    padding: 1rem 2.5rem;
    font-size: 1.1rem;
    font-weight: 700;
    border-radius: var(--radius-button);
    text-decoration: none;
    display: inline-block;
  }

  .cta-split__image {
    position: relative;
    min-height: 280px;
    overflow: hidden;
  }

  .cta-split__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    inset: 0;
  }

  .cta-split__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(0, 0, 0, 0.55) 0%,
      rgba(0, 0, 0, 0.3) 100%
    );
    z-index: 1;
  }

  /* Reversed variant: image first on desktop */
  @media (min-width: 768px) {
    .cta-split {
      grid-template-columns: 1fr 1fr;
    }

    .cta-split--reversed {
      direction: rtl;
    }

    .cta-split--reversed > * {
      direction: ltr;
    }

    .cta-split__content {
      padding: 5rem 3.5rem;
    }

    .cta-split__actions {
      flex-direction: row;
      flex-wrap: wrap;
      align-items: center;
    }

    .cta-split__image {
      min-height: 480px;
    }
  }

  @media (min-width: 1024px) {
    .cta-split__content {
      padding: 6rem 4rem;
    }
  }
</style>
