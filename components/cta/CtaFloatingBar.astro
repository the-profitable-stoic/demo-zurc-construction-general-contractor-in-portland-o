---
import { siteConfig, getVariant, hasEffect } from "../../lib/site-config";

const biz = siteConfig.business;
const variant = getVariant("cta");
const phoneHref = `tel:${biz.phone.replace(/[^+\d]/g, "")}`;
const useGlass = hasEffect("glass");
const isInline = variant === "inline";
---

{/* Inline section version (always rendered) */}
<section
  class:list={[
    "cta-bar-section",
    { "cta-bar-section--inline-only": isInline },
  ]}
  aria-label="Contact us"
>
  <div class="cta-bar-section__inner">
    <span class="cta-bar-section__name">{biz.name}</span>
    <div class="cta-bar-section__actions">
      <a href={phoneHref} class="cta-bar-section__phone" aria-label={`Call ${biz.name}`}>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span>{biz.phone}</span>
      </a>
      <a href="/contact" class="btn-primary cta-bar-section__btn">Get Estimate</a>
    </div>
  </div>
</section>

{/* Fixed mobile bar (only for "default" variant) */}
{!isInline && (
  <div
    class:list={["cta-floating", { "effect-glass": useGlass }]}
    role="complementary"
    aria-label="Quick contact"
  >
    <a href={phoneHref} class="cta-floating__phone" aria-label={`Call ${biz.name}`}>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      <span>{biz.phone}</span>
    </a>
    <a href="/contact" class="btn-primary cta-floating__btn">Get Estimate</a>
  </div>
)}

<style>
  /* ========== Inline section ========== */
  .cta-bar-section {
    background: var(--color-primary);
    color: var(--color-text-on-dark);
    padding: 1.25rem 1.5rem;
  }

  .cta-bar-section__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .cta-bar-section__name {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.1rem;
    white-space: nowrap;
  }

  .cta-bar-section__actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .cta-bar-section__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-text-on-dark);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .cta-bar-section__phone:hover {
    opacity: 0.85;
  }

  .cta-bar-section__btn {
    padding: 0.6rem 1.5rem;
    font-size: 0.9rem;
    font-weight: 700;
    border-radius: var(--radius-button);
    text-decoration: none;
    white-space: nowrap;
  }

  /* ========== Fixed floating bar (mobile only) ========== */
  .cta-floating {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.1);
  }

  .cta-floating__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .cta-floating__phone:hover {
    color: var(--color-primary);
  }

  .cta-floating__btn {
    padding: 0.6rem 1.25rem;
    font-size: 0.85rem;
    font-weight: 700;
    border-radius: var(--radius-button);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* Hide the floating bar on desktop */
  @media (min-width: 768px) {
    .cta-floating {
      display: none;
    }
  }

  /* On mobile, hide the inline section name to save space */
  @media (max-width: 767px) {
    .cta-bar-section__name {
      display: none;
    }

    .cta-bar-section__inner {
      justify-content: center;
    }
  }
</style>
