---
import { siteConfig } from '../../lib/site-config';

const { name, phone } = siteConfig.business;
const { ctaHeadline } = siteConfig.content.homepage;
const phoneHref = `tel:${phone.replace(/[^+\d]/g, '')}`;
---

<section class="inline-subtle section-padding" aria-label="Contact us">
  <div class="container">
    <div class="inline-subtle__inner animate-fade-up">
      <div class="inline-subtle__accent"></div>
      <p class="inline-subtle__text">{ctaHeadline}</p>
      <a href={phoneHref} class="inline-subtle__phone">{phone}</a>
      <p class="inline-subtle__note">Free estimates available</p>
    </div>
  </div>
</section>

<style>
  .inline-subtle {
    background: transparent;
  }

  .inline-subtle__inner {
    position: relative;
    padding-top: 1.5rem;
    max-width: 600px;
  }

  .inline-subtle__accent {
    position: absolute;
    top: 0;
    left: 0;
    width: 60px;
    height: 3px;
    background: var(--color-primary);
    border-radius: 2px;
  }

  .inline-subtle__text {
    font-family: var(--font-body);
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    line-height: 1.6;
    color: var(--color-text-light);
    margin: 0 0 0.75rem;
  }

  .inline-subtle__phone {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    color: inherit;
    text-decoration: none;
    display: inline-block;
    line-height: 1.2;
    transition: color 0.2s ease;
  }

  .inline-subtle__phone:hover {
    color: var(--color-primary);
  }

  .inline-subtle__note {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-light);
    margin: 0.5rem 0 0;
    letter-spacing: 0.02em;
  }
</style>
