---
import { siteConfig } from "../../lib/site-config";

const { ctaHeadline, ctaSubline } = siteConfig.content.homepage;
const { phone, name: businessName } = siteConfig.business;

const phoneHref = `tel:${phone.replace(/[^+\d]/g, "")}`;
---

<section class="cta-banner animate-fade-up" aria-label="Call to action">
  <div class="cta-banner__bg" aria-hidden="true"></div>
  <div class="cta-banner__container">
    <h2 class="cta-banner__headline animate-fade-in">{ctaHeadline}</h2>
    {ctaSubline && (
      <p class="cta-banner__subline animate-fade-in">{ctaSubline}</p>
    )}
    <div class="cta-banner__actions animate-scale-in">
      <a href="/contact" class="cta-banner__btn cta-banner__btn--quote">
        Get Your Free Quote
      </a>
      <a href={phoneHref} class="cta-banner__btn cta-banner__btn--phone" aria-label={`Call ${businessName} at ${phone}`}>
        <svg class="cta-banner__phone-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.362 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.574 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {phone}
      </a>
    </div>
  </div>
</section>

<style>
  .cta-banner {
    position: relative;
    overflow: hidden;
    padding: clamp(3.5rem, 8vw, 6rem) 1.25rem;
  }

  .cta-banner__bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    z-index: 0;
  }

  .cta-banner__bg::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at 30% 0%,
      rgba(255, 255, 255, 0.1) 0%,
      transparent 60%
    );
  }

  .cta-banner__container {
    position: relative;
    z-index: 1;
    max-width: 820px;
    margin: 0 auto;
    text-align: center;
  }

  .cta-banner__headline {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: clamp(1.75rem, 4.5vw, 3rem);
    color: var(--color-text-on-dark);
    margin: 0 0 1rem;
    line-height: 1.15;
    letter-spacing: -0.01em;
  }

  .cta-banner__subline {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-text-on-dark);
    opacity: 0.88;
    margin: 0 0 2.25rem;
    line-height: 1.6;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-banner__actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  @media (min-width: 540px) {
    .cta-banner__actions {
      flex-direction: row;
      justify-content: center;
      gap: 1.25rem;
    }
  }

  .cta-banner__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.95rem 2rem;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    border-radius: var(--radius-button);
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    white-space: nowrap;
    cursor: pointer;
    line-height: 1.3;
  }

  .cta-banner__btn:hover {
    transform: translateY(-2px);
  }

  .cta-banner__btn:active {
    transform: translateY(0);
  }

  .cta-banner__btn--quote {
    background: var(--color-text-on-dark);
    color: var(--color-primary);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .cta-banner__btn--quote:hover {
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.2);
  }

  .cta-banner__btn--phone {
    background: transparent;
    color: var(--color-text-on-dark);
    border: 2px solid rgba(255, 255, 255, 0.45);
  }

  .cta-banner__btn--phone:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.7);
  }

  .cta-banner__phone-icon {
    flex-shrink: 0;
  }

  /* Ensure full-width bleed when inside constrained parents */
  @supports (margin-inline: calc(-50vw + 50%)) {
    .cta-banner {
      margin-inline: calc(-50vw + 50%);
      width: 100vw;
    }
  }
</style>
