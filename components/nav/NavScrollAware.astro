---
import { siteConfig, getVariant, hasEffect } from "../../lib/site-config";

const biz = siteConfig.business;
const services = siteConfig.content.services;
const serviceAreas = siteConfig.content.serviceAreas;
const variant = getVariant("nav");
const phoneHref = `tel:${biz.phone.replace(/[^+\d]/g, "")}`;
const isMinimal = variant === "minimal";
---

<header class:list={["scroll-nav", { "scroll-nav--minimal": isMinimal }]} id="scroll-nav">
  <nav class="scroll-nav__inner" aria-label="Main navigation">
    <a href="/" class="scroll-nav__brand" aria-label={`${biz.name} home`}>
      {biz.name}
    </a>

    <div class="scroll-nav__links">
      <a href="/" class="scroll-nav__link">Home</a>
      <a href="/about" class="scroll-nav__link">About</a>
      <div class="nav-dropdown">
        <button class="scroll-nav__link nav-dropdown-trigger" aria-expanded="false" aria-haspopup="true">
          Services <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
        <div class="nav-dropdown-menu" role="menu">
          <a href="/services" class="dropdown-link" role="menuitem">All Services</a>
          {services.slice(0, 6).map((s) => (
            <a href={`/services/${s.slug}`} class="dropdown-link" role="menuitem">{s.name}</a>
          ))}
        </div>
      </div>
      {serviceAreas.length > 0 && (
        <div class="nav-dropdown">
          <button class="scroll-nav__link nav-dropdown-trigger" aria-expanded="false" aria-haspopup="true">
            Service Areas <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </button>
          <div class="nav-dropdown-menu nav-dropdown-menu--wide" role="menu">
            <a href="/service-areas" class="dropdown-link" role="menuitem">All Service Areas</a>
            {serviceAreas.slice(0, 8).map((a) => (
              <a href={`/service-areas/${a.slug}`} class="dropdown-link" role="menuitem">{a.city}, {a.state}</a>
            ))}
          </div>
        </div>
      )}
      <a href="/reviews" class="scroll-nav__link">Reviews</a>
      <a href="/contact" class="scroll-nav__link">Contact</a>
    </div>

    <div class="scroll-nav__actions">
      <a href={phoneHref} class="scroll-nav__phone" aria-label={`Call ${biz.phone}`}>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span>{biz.phone}</span>
      </a>
      <a href="/contact" class="btn-primary scroll-nav__cta">Free Quote</a>
    </div>

    <details class="scroll-nav__mobile-toggle" id="nav-details">
      <summary class="scroll-nav__hamburger" aria-label="Open navigation menu">
        <span class="scroll-nav__hamburger-icon" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
      </summary>
      <div class="scroll-nav__mobile-menu">
        <a href="/" class="scroll-nav__mobile-link">Home</a>
        <a href="/about" class="scroll-nav__mobile-link">About</a>
        <details class="mobile-dropdown">
          <summary class="scroll-nav__mobile-link mobile-dropdown-trigger">
            Services <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </summary>
          <div class="mobile-dropdown-menu">
            <a href="/services" class="mobile-dropdown-link">All Services</a>
            {services.slice(0, 6).map((s) => (
              <a href={`/services/${s.slug}`} class="mobile-dropdown-link">{s.name}</a>
            ))}
          </div>
        </details>
        {serviceAreas.length > 0 && (
          <details class="mobile-dropdown">
            <summary class="scroll-nav__mobile-link mobile-dropdown-trigger">
              Service Areas <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </summary>
            <div class="mobile-dropdown-menu">
              <a href="/service-areas" class="mobile-dropdown-link">All Service Areas</a>
              {serviceAreas.slice(0, 8).map((a) => (
                <a href={`/service-areas/${a.slug}`} class="mobile-dropdown-link">{a.city}, {a.state}</a>
              ))}
            </div>
          </details>
        )}
        <a href="/reviews" class="scroll-nav__mobile-link">Reviews</a>
        <a href="/contact" class="scroll-nav__mobile-link">Contact</a>
        <a href={phoneHref} class="btn-primary scroll-nav__mobile-cta">
          Call {biz.phone}
        </a>
      </div>
    </details>
  </nav>
</header>

<style>
  /* ========== Scroll-driven animation ========== */
  @keyframes nav-solidify {
    from {
      background: transparent;
      color: var(--color-text-on-dark, #fff);
      border-bottom-color: transparent;
    }
    to {
      background: var(--color-background);
      color: var(--color-text);
      border-bottom-color: var(--color-border);
      box-shadow: 0 1px 10px rgba(0, 0, 0, 0.06);
    }
  }

  @keyframes nav-solidify-minimal {
    from {
      background: rgba(0, 0, 0, 0.15);
      color: var(--color-text-on-dark, #fff);
      border-bottom-color: transparent;
    }
    to {
      background: rgba(255, 255, 255, 0.92);
      color: var(--color-text);
      border-bottom-color: var(--color-border);
      box-shadow: 0 1px 10px rgba(0, 0, 0, 0.06);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }
  }

  .scroll-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    border-bottom: 1px solid transparent;
    animation: nav-solidify linear both;
    animation-timeline: scroll();
    animation-range: 0px 300px;
  }

  .scroll-nav--minimal {
    animation-name: nav-solidify-minimal;
  }

  .scroll-nav__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  /* ========== Brand ========== */
  .scroll-nav__brand {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.35rem;
    color: inherit;
    text-decoration: none;
    flex-shrink: 0;
    letter-spacing: -0.02em;
    transition: opacity 0.2s ease;
  }

  .scroll-nav__brand:hover {
    opacity: 0.8;
  }

  /* ========== Desktop links ========== */
  .scroll-nav__links {
    display: none;
    align-items: center;
    gap: 0.25rem;
  }

  .scroll-nav__link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    color: inherit;
    text-decoration: none;
    padding: 0.5rem 0.85rem;
    border-radius: var(--radius);
    transition: background 0.2s ease, opacity 0.2s ease;
    white-space: nowrap;
    background: none;
    border: none;
    cursor: pointer;
  }

  .scroll-nav__link:hover {
    background: rgba(128, 128, 128, 0.12);
  }

  /* ========== Dropdown (desktop) ========== */
  .nav-dropdown { position: relative; }
  .nav-dropdown-menu {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 220px;
    padding: 0.5rem 0;
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1);
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: all 0.2s ease;
    z-index: 100;
  }
  .nav-dropdown:hover .nav-dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .dropdown-link {
    display: block;
    padding: 0.6rem 1.25rem;
    font-size: 0.88rem;
    color: var(--color-text);
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }
  .dropdown-link:hover {
    background: var(--color-surface);
    color: var(--color-primary);
  }
  .nav-dropdown-menu--wide {
    min-width: 240px;
    columns: 2;
    column-gap: 0;
  }

  /* ========== Desktop actions ========== */
  .scroll-nav__actions {
    display: none;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  .scroll-nav__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.88rem;
    font-weight: 600;
    color: inherit;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .scroll-nav__phone:hover { opacity: 0.8; }

  .scroll-nav__cta {
    padding: 0.6rem 1.4rem;
    font-size: 0.85rem;
    white-space: nowrap;
  }

  /* ========== Mobile hamburger (details/summary - CSS only) ========== */
  .scroll-nav__mobile-toggle {
    display: block;
    position: relative;
  }

  .scroll-nav__hamburger {
    list-style: none;
    cursor: pointer;
    padding: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .scroll-nav__hamburger::-webkit-details-marker {
    display: none;
  }

  .scroll-nav__hamburger-icon {
    display: flex;
    flex-direction: column;
    gap: 5px;
    width: 24px;
  }

  .scroll-nav__hamburger-icon span {
    display: block;
    height: 2px;
    width: 100%;
    background: currentColor;
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  details[open] .scroll-nav__hamburger-icon span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  details[open] .scroll-nav__hamburger-icon span:nth-child(2) {
    opacity: 0;
  }

  details[open] .scroll-nav__hamburger-icon span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .scroll-nav__mobile-menu {
    position: absolute;
    top: calc(100% + 0.75rem);
    right: 0;
    min-width: 280px;
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15);
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    z-index: 101;
  }

  .scroll-nav__mobile-link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.75rem 1rem;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    border-radius: var(--radius);
    transition: background 0.15s ease;
    cursor: pointer;
    list-style: none;
  }

  .scroll-nav__mobile-link:hover {
    background: var(--color-surface);
  }

  /* Mobile dropdown (details/summary - CSS only) */
  .mobile-dropdown {
    border: none;
  }

  .mobile-dropdown-trigger {
    list-style: none;
  }

  .mobile-dropdown-trigger::-webkit-details-marker {
    display: none;
  }

  .mobile-dropdown-trigger svg {
    transition: transform 0.2s ease;
  }

  .mobile-dropdown[open] .mobile-dropdown-trigger svg {
    transform: rotate(180deg);
  }

  .mobile-dropdown-menu {
    padding: 0.25rem 0 0.25rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .mobile-dropdown-link {
    display: block;
    padding: 0.55rem 1rem;
    font-size: 0.9rem;
    color: var(--color-text);
    text-decoration: none;
    border-radius: var(--radius);
    transition: background 0.15s, color 0.15s;
  }

  .mobile-dropdown-link:hover {
    background: var(--color-surface);
    color: var(--color-primary);
  }

  .scroll-nav__mobile-cta {
    display: block;
    text-align: center;
    margin-top: 0.5rem;
    padding: 0.75rem 1rem;
    font-size: 0.95rem;
    font-weight: 700;
    border-radius: var(--radius-button, var(--radius));
    text-decoration: none;
  }

  /* ========== Desktop breakpoint ========== */
  @media (min-width: 1024px) {
    .scroll-nav__links {
      display: flex;
    }

    .scroll-nav__actions {
      display: flex;
    }

    .scroll-nav__mobile-toggle {
      display: none;
    }

    .nav-dropdown-menu--wide {
      columns: 2;
    }
  }

  @media (max-width: 1023px) {
    .nav-dropdown-menu--wide {
      columns: 1;
    }
  }

  @media (max-width: 640px) {
    .scroll-nav__inner { height: 64px; }
  }
</style>
