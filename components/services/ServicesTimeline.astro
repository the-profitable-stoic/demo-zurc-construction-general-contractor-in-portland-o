---
import { siteConfig, getVariant, hasEffect } from "../../lib/site-config";

const services = siteConfig.content.services;
const serviceImages = siteConfig.images.services;
const biz = siteConfig.business;
const variant = getVariant("services");
---

<section class="timeline-services section-padding" aria-labelledby="timeline-services-heading" data-variant={variant}>
  <div class="timeline-services__container">
    <div class="timeline-services__header animate-fade-up">
      <p class="timeline-services__label">What We Do</p>
      <h2 id="timeline-services-heading" class="timeline-services__title">Our Services</h2>
    </div>

    <div class="timeline-services__track">
      <div class="timeline-services__line" aria-hidden="true" />

      {services.map((service, i) => (
        <div
          class:list={[
            "timeline-services__entry",
            `timeline-services__entry--${i % 2 === 0 ? "left" : "right"}`,
            "animate-fade-up",
            "animate-stagger",
          ]}
          style={`--stagger-index: ${i}`}
        >
          <div class="timeline-services__dot" aria-hidden="true" />

          <a href={`/services/${service.slug}`} class="timeline-services__card" aria-label={`Learn more about ${service.name}`}>
            {serviceImages[service.slug] && (
              <div class="timeline-services__thumb-wrap">
                <img
                  src={serviceImages[service.slug]}
                  alt={service.name}
                  class="timeline-services__thumb"
                  loading="lazy"
                  width="280"
                  height="180"
                />
              </div>
            )}
            <div class="timeline-services__body">
              <h3 class="timeline-services__name">{service.name}</h3>
              <p class="timeline-services__desc">{service.shortDescription}</p>
              <span class="timeline-services__link" aria-hidden="true">
                Learn More <span class="timeline-services__arrow">&rarr;</span>
              </span>
            </div>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .timeline-services {
    background: var(--color-background);
  }

  .timeline-services__container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .timeline-services__header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .timeline-services__label {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 0.75rem;
  }

  .timeline-services__title {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: clamp(2rem, 4vw, 3rem);
    color: inherit;
    margin: 0;
    line-height: 1.15;
  }

  /* ---- Track & Line ---- */
  .timeline-services__track {
    position: relative;
    padding: 1rem 0;
  }

  .timeline-services__line {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-border);
  }

  /* Default: center line */
  [data-variant="default"] .timeline-services__line {
    left: 50%;
    transform: translateX(-50%);
  }

  /* Compact: left-edge line */
  [data-variant="compact"] .timeline-services__line {
    left: 1rem;
  }

  /* ---- Entry ---- */
  .timeline-services__entry {
    position: relative;
    margin-bottom: 2.5rem;
  }

  .timeline-services__entry:last-child {
    margin-bottom: 0;
  }

  /* ---- Dot ---- */
  .timeline-services__dot {
    position: absolute;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-primary);
    border: 3px solid var(--color-background);
    box-shadow: 0 0 0 2px var(--color-primary);
    z-index: 2;
    top: 2rem;
  }

  /* Default variant dot positioning */
  [data-variant="default"] .timeline-services__dot {
    left: 50%;
    transform: translateX(-50%);
  }

  /* Compact variant dot positioning */
  [data-variant="compact"] .timeline-services__dot {
    left: 1rem;
    transform: translateX(-50%);
  }

  /* ---- Card ---- */
  .timeline-services__card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .timeline-services__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.1);
  }

  .timeline-services__card:focus-visible {
    outline: 3px solid var(--color-primary);
    outline-offset: 2px;
  }

  /* ---- Default variant: alternating sides ---- */
  [data-variant="default"] .timeline-services__entry {
    width: 45%;
  }

  [data-variant="default"] .timeline-services__entry--left {
    margin-right: auto;
    margin-left: 0;
    padding-right: 2rem;
  }

  [data-variant="default"] .timeline-services__entry--right {
    margin-left: auto;
    margin-right: 0;
    padding-left: 2rem;
  }

  /* ---- Compact variant: all on right ---- */
  [data-variant="compact"] .timeline-services__entry {
    width: auto;
    padding-left: 3rem;
  }

  /* ---- Mobile: always compact layout ---- */
  @media (max-width: 767px) {
    .timeline-services__line {
      left: 1rem !important;
      transform: none !important;
    }

    .timeline-services__dot {
      left: 1rem !important;
      transform: translateX(-50%) !important;
    }

    .timeline-services__entry {
      width: auto !important;
      padding-left: 3rem !important;
      padding-right: 0 !important;
      margin-left: 0 !important;
      margin-right: 0 !important;
    }
  }

  /* ---- Thumbnail ---- */
  .timeline-services__thumb-wrap {
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .timeline-services__thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease;
  }

  .timeline-services__card:hover .timeline-services__thumb {
    transform: scale(1.05);
  }

  /* ---- Body ---- */
  .timeline-services__body {
    padding: 1.25rem 1.5rem 1.5rem;
  }

  .timeline-services__name {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: clamp(1.05rem, 1.8vw, 1.25rem);
    color: inherit;
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .timeline-services__desc {
    font-family: var(--font-body);
    font-size: 0.925rem;
    color: inherit;
    opacity: 0.7;
    line-height: 1.65;
    margin: 0 0 1rem;
  }

  .timeline-services__link {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary);
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    transition: gap 0.25s ease;
  }

  .timeline-services__card:hover .timeline-services__link {
    gap: 0.6rem;
  }

  .timeline-services__arrow {
    font-size: 1.1em;
    transition: transform 0.25s ease;
  }

  .timeline-services__card:hover .timeline-services__arrow {
    transform: translateX(2px);
  }
</style>
