---
import { siteConfig } from '../../lib/site-config';

const services = siteConfig.content.services;
const serviceImages = siteConfig.images.services;
---

<section class="tabbed-showcase section-padding">
  <div class="container">
    <div class="tabbed-showcase-header animate-fade-up">
      <p class="tabbed-showcase-label">Our Services</p>
      <h2 class="tabbed-showcase-title">What We Offer</h2>
    </div>

    <div class="tabbed-showcase-wrapper animate-fade-up">
      {/* Tab navigation — uses radio buttons for pure CSS tab switching */}
      <nav class="tabbed-showcase-nav" role="tablist" aria-label="Service tabs">
        <div class="tabbed-showcase-nav-scroll">
          {services.map((service, i) => (
            <label class="tabbed-showcase-tab" role="tab">
              <input
                type="radio"
                name="service-tab"
                class="tabbed-showcase-radio"
                checked={i === 0}
                aria-label={service.name}
              />
              <span class="tabbed-showcase-tab-text">{service.name}</span>
            </label>
          ))}
        </div>
      </nav>

      {/* Tab panels */}
      <div class="tabbed-showcase-panels">
        {services.map((service, i) => (
          <div class="tabbed-showcase-panel" data-panel={i}>
            <div class="tabbed-showcase-panel-inner">
              <div class="tabbed-showcase-image-wrap">
                {serviceImages[service.slug] ? (
                  <img
                    src={serviceImages[service.slug]}
                    alt={service.name}
                    class="tabbed-showcase-image"
                    loading={i === 0 ? 'eager' : 'lazy'}
                    width="600"
                    height="400"
                  />
                ) : (
                  <div class="tabbed-showcase-image-placeholder" aria-hidden="true">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <rect x="3" y="3" width="18" height="18" rx="2" />
                      <circle cx="8.5" cy="8.5" r="1.5" />
                      <path d="M21 15l-5-5L5 21" />
                    </svg>
                  </div>
                )}
              </div>

              <div class="tabbed-showcase-info">
                <h3 class="tabbed-showcase-name">{service.name}</h3>
                <p class="tabbed-showcase-desc">{service.shortDescription}</p>

                {service.benefits && service.benefits.length > 0 && (
                  <ul class="tabbed-showcase-benefits" role="list">
                    {service.benefits.map((benefit) => (
                      <li class="tabbed-showcase-benefit">
                        <svg class="tabbed-showcase-check" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <polyline points="20 6 9 17 4 12" />
                        </svg>
                        <span>{benefit}</span>
                      </li>
                    ))}
                  </ul>
                )}

                <a href={`/services/${service.slug}`} class="btn-primary tabbed-showcase-cta">
                  Learn More
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .tabbed-showcase {
    background: var(--color-background);
  }

  .tabbed-showcase-header {
    margin-bottom: 2.5rem;
  }

  .tabbed-showcase-label {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 0.75rem;
  }

  .tabbed-showcase-title {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: clamp(2rem, 4vw, 3rem);
    color: inherit;
    margin: 0;
    line-height: 1.15;
  }

  .tabbed-showcase-wrapper {
    background: var(--color-surface);
    border-radius: var(--radius-card);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  /* Tab navigation */
  .tabbed-showcase-nav {
    border-bottom: 2px solid var(--color-border);
    background: var(--color-background-alt);
  }

  .tabbed-showcase-nav-scroll {
    display: flex;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    -webkit-overflow-scrolling: touch;
  }

  .tabbed-showcase-nav-scroll::-webkit-scrollbar {
    display: none;
  }

  .tabbed-showcase-tab {
    flex: 0 0 auto;
    cursor: pointer;
    position: relative;
  }

  .tabbed-showcase-radio {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .tabbed-showcase-tab-text {
    display: block;
    padding: 1rem 1.5rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    color: inherit; opacity: 0.7;
    white-space: nowrap;
    border-bottom: 3px solid transparent;
    margin-bottom: -2px;
    transition: color 0.25s ease, border-color 0.25s ease;
  }

  .tabbed-showcase-radio:checked + .tabbed-showcase-tab-text {
    color: var(--color-primary);
    font-weight: 600;
    border-bottom-color: var(--color-primary);
  }

  .tabbed-showcase-tab:hover .tabbed-showcase-tab-text {
    color: inherit;
  }

  /* Panels — CSS-only switching via :has() */
  .tabbed-showcase-panels {
    position: relative;
  }

  .tabbed-showcase-panel {
    display: none;
    padding: 2rem;
  }

  /* Show the panel corresponding to the checked radio by index */
  .tabbed-showcase-wrapper:has(.tabbed-showcase-tab:nth-child(1) .tabbed-showcase-radio:checked) .tabbed-showcase-panel:nth-child(1),
  .tabbed-showcase-wrapper:has(.tabbed-showcase-tab:nth-child(2) .tabbed-showcase-radio:checked) .tabbed-showcase-panel:nth-child(2),
  .tabbed-showcase-wrapper:has(.tabbed-showcase-tab:nth-child(3) .tabbed-showcase-radio:checked) .tabbed-showcase-panel:nth-child(3),
  .tabbed-showcase-wrapper:has(.tabbed-showcase-tab:nth-child(4) .tabbed-showcase-radio:checked) .tabbed-showcase-panel:nth-child(4),
  .tabbed-showcase-wrapper:has(.tabbed-showcase-tab:nth-child(5) .tabbed-showcase-radio:checked) .tabbed-showcase-panel:nth-child(5),
  .tabbed-showcase-wrapper:has(.tabbed-showcase-tab:nth-child(6) .tabbed-showcase-radio:checked) .tabbed-showcase-panel:nth-child(6),
  .tabbed-showcase-wrapper:has(.tabbed-showcase-tab:nth-child(7) .tabbed-showcase-radio:checked) .tabbed-showcase-panel:nth-child(7),
  .tabbed-showcase-wrapper:has(.tabbed-showcase-tab:nth-child(8) .tabbed-showcase-radio:checked) .tabbed-showcase-panel:nth-child(8) {
    display: block;
  }

  .tabbed-showcase-panel-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }

  /* Image */
  .tabbed-showcase-image-wrap {
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 3 / 2;
    background: var(--color-background-alt);
  }

  .tabbed-showcase-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .tabbed-showcase-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: inherit; opacity: 0.7;
    opacity: 0.4;
  }

  /* Info */
  .tabbed-showcase-name {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    color: inherit;
    margin: 0 0 0.75rem;
    line-height: 1.25;
  }

  .tabbed-showcase-desc {
    font-family: var(--font-body);
    font-size: 1rem;
    color: inherit; opacity: 0.7;
    line-height: 1.65;
    margin: 0 0 1.25rem;
  }

  .tabbed-showcase-benefits {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .tabbed-showcase-benefit {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-family: var(--font-body);
    font-size: 0.925rem;
    color: inherit;
    line-height: 1.5;
  }

  .tabbed-showcase-check {
    flex-shrink: 0;
    color: var(--color-primary);
    margin-top: 0.15rem;
  }

  .tabbed-showcase-cta {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }

  /* Desktop: side-by-side layout */
  @media (min-width: 768px) {
    .tabbed-showcase-panel {
      padding: 2.5rem;
    }

    .tabbed-showcase-panel-inner {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: center;
    }
  }

  @media (min-width: 1024px) {
    .tabbed-showcase-panel {
      padding: 3rem;
    }

    .tabbed-showcase-tab-text {
      padding: 1.15rem 2rem;
      font-size: 0.95rem;
    }
  }
</style>
