---
import { siteConfig } from '../../lib/site-config';

const { name, phone, city, state } = siteConfig.business;
const services = siteConfig.content.services || [];
const phoneHref = `tel:${phone.replace(/[^+\d]/g, '')}`;
const emailAddress = `info@${name.toLowerCase().replace(/[^a-z0-9]/g, '')}.com`;
---

<section class="fullwidth-form" aria-label="Contact form">
  <div class="container">
    <div class="fullwidth-form__inner">
      <div class="fullwidth-form__header animate-fade-up">
        <h2 class="fullwidth-form__title">Let's Talk About Your Project</h2>
        <p class="fullwidth-form__subtitle">Fill out the form below and we'll get back to you within 24 hours.</p>
      </div>

      <form class="fullwidth-form__form animate-fade-up" action="/api/contact" method="POST">
        <div class="fullwidth-form__row">
          <div class="fullwidth-form__field">
            <label for="fw-name" class="fullwidth-form__label">Full Name</label>
            <input type="text" id="fw-name" name="name" required placeholder="John Smith" class="fullwidth-form__input" />
          </div>
          <div class="fullwidth-form__field">
            <label for="fw-email" class="fullwidth-form__label">Email Address</label>
            <input type="email" id="fw-email" name="email" required placeholder="john@example.com" class="fullwidth-form__input" />
          </div>
        </div>

        <div class="fullwidth-form__row">
          <div class="fullwidth-form__field">
            <label for="fw-phone" class="fullwidth-form__label">Phone Number</label>
            <input type="tel" id="fw-phone" name="phone" placeholder="(555) 123-4567" class="fullwidth-form__input" />
          </div>
          <div class="fullwidth-form__field">
            <label for="fw-service" class="fullwidth-form__label">Service Needed</label>
            <select id="fw-service" name="service" class="fullwidth-form__input fullwidth-form__select">
              <option value="">Select a service</option>
              {services.map((s) => (
                <option value={s.slug}>{s.name}</option>
              ))}
            </select>
          </div>
        </div>

        <div class="fullwidth-form__field fullwidth-form__field--full">
          <label for="fw-message" class="fullwidth-form__label">Tell Us About Your Project</label>
          <textarea id="fw-message" name="message" rows="5" placeholder="Describe your project, timeline, and any specific requirements..." class="fullwidth-form__input fullwidth-form__textarea"></textarea>
        </div>

        <button type="submit" class="btn-primary fullwidth-form__submit">Send Message</button>
      </form>

      <div class="fullwidth-form__info animate-fade-up">
        <div class="fullwidth-form__info-item">
          <svg class="fullwidth-form__info-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.362 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <div>
            <span class="fullwidth-form__info-label">Phone</span>
            <a href={phoneHref} class="fullwidth-form__info-value">{phone}</a>
          </div>
        </div>
        <div class="fullwidth-form__info-item">
          <svg class="fullwidth-form__info-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <div>
            <span class="fullwidth-form__info-label">Email</span>
            <a href={`mailto:${emailAddress}`} class="fullwidth-form__info-value">{emailAddress}</a>
          </div>
        </div>
        <div class="fullwidth-form__info-item">
          <svg class="fullwidth-form__info-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <div>
            <span class="fullwidth-form__info-label">Location</span>
            <span class="fullwidth-form__info-value">{city}, {state}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .fullwidth-form {
    background: var(--color-text);
    color: var(--color-text-on-dark);
    padding: clamp(3rem, 6vw, 5rem) 0;
  }

  .fullwidth-form__inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .fullwidth-form__header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .fullwidth-form__title {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin: 0 0 0.75rem;
    color: var(--color-text-on-dark);
  }

  .fullwidth-form__subtitle {
    font-family: var(--font-body);
    font-size: 1.05rem;
    opacity: 0.7;
    margin: 0;
  }

  .fullwidth-form__form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .fullwidth-form__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .fullwidth-form__label {
    display: block;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 0.4rem;
    opacity: 0.85;
    letter-spacing: 0.02em;
  }

  .fullwidth-form__input {
    width: 100%;
    padding: 0.8rem 1rem;
    font-family: var(--font-body);
    font-size: 1rem;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: var(--radius);
    color: var(--color-text-on-dark);
    transition: border-color 0.2s ease, background 0.2s ease;
    box-sizing: border-box;
  }

  .fullwidth-form__input::placeholder {
    color: rgba(255, 255, 255, 0.35);
  }

  .fullwidth-form__input:focus {
    outline: none;
    border-color: var(--color-primary);
    background: rgba(255, 255, 255, 0.12);
  }

  .fullwidth-form__select {
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='rgba(255,255,255,0.5)' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    padding-right: 2.5rem;
  }

  .fullwidth-form__textarea {
    resize: vertical;
    min-height: 120px;
  }

  .fullwidth-form__submit {
    align-self: center;
    margin-top: 0.5rem;
    padding: 1rem 3rem;
    font-size: 1.1rem;
    border: none;
    cursor: pointer;
    border-radius: var(--radius-button);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .fullwidth-form__submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
  }

  .fullwidth-form__info {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-top: 3rem;
    padding-top: 2.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .fullwidth-form__info-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .fullwidth-form__info-icon {
    flex-shrink: 0;
    opacity: 0.6;
    margin-top: 0.15rem;
  }

  .fullwidth-form__info-label {
    display: block;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.5;
    margin-bottom: 0.15rem;
  }

  .fullwidth-form__info-value {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text-on-dark);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  a.fullwidth-form__info-value:hover {
    opacity: 0.8;
  }

  @media (min-width: 600px) {
    .fullwidth-form__row {
      grid-template-columns: 1fr 1fr;
    }

    .fullwidth-form__info {
      grid-template-columns: repeat(3, 1fr);
      text-align: center;
    }

    .fullwidth-form__info-item {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
