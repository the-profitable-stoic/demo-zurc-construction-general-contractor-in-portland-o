---
import { siteConfig } from '../../lib/site-config';

const services = siteConfig.content.services;
const serviceImages = siteConfig.images.services;
---

<section class="accordion-services section-padding">
  <div class="container">
    <div class="accordion-services-header animate-fade-up">
      <p class="accordion-services-label">What We Do</p>
      <h2 class="accordion-services-title">Our Expertise</h2>
    </div>

    <div class="accordion-services-list">
      {services.map((service, i) => (
        <details
          class="accordion-services-item animate-fade-up animate-stagger"
          style={`--stagger-index: ${i}`}
          open={i === 0}
        >
          <summary class="accordion-services-summary">
            <div class="accordion-services-summary-content">
              <h3 class="accordion-services-name">{service.name}</h3>
              <p class="accordion-services-short">{service.shortDescription}</p>
            </div>
            <span class="accordion-services-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19" class="accordion-services-icon-v" />
                <line x1="5" y1="12" x2="19" y2="12" />
              </svg>
            </span>
          </summary>

          <div class="accordion-services-detail">
            <div class="accordion-services-detail-inner">
              {serviceImages[service.slug] && (
                <div class="accordion-services-image-wrap">
                  <img
                    src={serviceImages[service.slug]}
                    alt={service.name}
                    class="accordion-services-image"
                    loading="lazy"
                    width="500"
                    height="340"
                  />
                </div>
              )}

              <div class="accordion-services-detail-body">
                <p class="accordion-services-desc">{service.description}</p>

                {service.benefits && service.benefits.length > 0 && (
                  <ul class="accordion-services-benefits" role="list">
                    {service.benefits.map((benefit) => (
                      <li class="accordion-services-benefit">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="accordion-services-benefit-icon">
                          <polyline points="20 6 9 17 4 12" />
                        </svg>
                        {benefit}
                      </li>
                    ))}
                  </ul>
                )}

                <a href={`/services/${service.slug}`} class="btn-secondary accordion-services-cta">
                  View Full Details &rarr;
                </a>
              </div>
            </div>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .accordion-services {
    background: var(--color-background);
  }

  .accordion-services-header {
    margin-bottom: 3rem;
  }

  .accordion-services-label {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 0.75rem;
  }

  .accordion-services-title {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: clamp(2rem, 4vw, 3rem);
    color: inherit;
    margin: 0;
    line-height: 1.15;
  }

  .accordion-services-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--color-border);
  }

  /* Details / Summary */
  .accordion-services-item {
    border-bottom: 1px solid var(--color-border);
  }

  .accordion-services-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.5rem 0.5rem;
    cursor: pointer;
    list-style: none;
    transition: background-color 0.25s ease;
  }

  .accordion-services-summary::-webkit-details-marker {
    display: none;
  }

  .accordion-services-summary::marker {
    content: '';
  }

  .accordion-services-summary:hover {
    background-color: var(--color-background-alt);
  }

  .accordion-services-summary-content {
    min-width: 0;
    flex: 1;
  }

  .accordion-services-name {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    color: inherit;
    margin: 0 0 0.25rem;
    line-height: 1.3;
  }

  .accordion-services-short {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: inherit; opacity: 0.7;
    margin: 0;
    line-height: 1.5;
  }

  /* Expand/collapse icon */
  .accordion-services-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 2px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: inherit; opacity: 0.7;
    transition: border-color 0.25s ease, color 0.25s ease, transform 0.3s ease;
  }

  .accordion-services-item:hover .accordion-services-icon {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .accordion-services-icon-v {
    transition: transform 0.3s ease, opacity 0.3s ease;
    transform-origin: center;
  }

  .accordion-services-item[open] .accordion-services-icon-v {
    transform: scaleY(0);
    opacity: 0;
  }

  .accordion-services-item[open] .accordion-services-icon {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: var(--color-primary-light);
  }

  /* Detail panel */
  .accordion-services-detail {
    padding: 0 0.5rem 2rem;
  }

  .accordion-services-detail-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    padding-top: 0.5rem;
  }

  .accordion-services-image-wrap {
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 3 / 2;
    background: var(--color-background-alt);
  }

  .accordion-services-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .accordion-services-detail-body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .accordion-services-desc {
    font-family: var(--font-body);
    font-size: 0.975rem;
    color: inherit;
    line-height: 1.7;
    margin: 0;
  }

  .accordion-services-benefits {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .accordion-services-benefit {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: inherit;
    line-height: 1.5;
  }

  .accordion-services-benefit-icon {
    flex-shrink: 0;
    color: var(--color-primary);
    margin-top: 0.15rem;
  }

  .accordion-services-cta {
    display: inline-flex;
    align-self: flex-start;
    text-decoration: none;
    margin-top: 0.5rem;
  }

  /* Desktop: side-by-side image + text */
  @media (min-width: 768px) {
    .accordion-services-detail-inner {
      grid-template-columns: 280px 1fr;
      gap: 2rem;
      align-items: start;
    }

    .accordion-services-summary {
      padding: 1.75rem 1rem;
    }

    .accordion-services-detail {
      padding: 0 1rem 2.5rem;
    }
  }

  @media (min-width: 1024px) {
    .accordion-services-detail-inner {
      grid-template-columns: 340px 1fr;
      gap: 2.5rem;
    }
  }
</style>
