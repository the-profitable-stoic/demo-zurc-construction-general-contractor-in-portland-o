---
import { siteConfig } from '../../lib/site-config';

const images = siteConfig.images.gallery || [];
const { name, category } = siteConfig.business;

// Pair images: 0+1, 2+3, etc.
const pairs: { before: string; after: string }[] = [];
let showcase: string | null = null;

for (let i = 0; i < images.length - 1; i += 2) {
  pairs.push({ before: images[i], after: images[i + 1] });
}
if (images.length % 2 !== 0) {
  showcase = images[images.length - 1];
}
---

<section class="before-after section-padding" aria-label="Before and after gallery">
  <div class="container">
    <div class="before-after__header animate-fade-up">
      <h2 class="before-after__title">See the Difference</h2>
      <p class="before-after__subtitle">Real results from our {category.toLowerCase()} projects</p>
    </div>

    <div class="before-after__pairs animate-stagger">
      {pairs.map((pair, i) => (
        <div class="before-after__pair animate-fade-up">
          <div class="before-after__image-wrap before-after__image-wrap--before">
            <span class="before-after__label before-after__label--before">Before</span>
            <img
              src={pair.before}
              alt={`${name} project ${i + 1} - before`}
              class="before-after__img"
              loading="lazy"
              width="600"
              height="450"
            />
          </div>
          <div class="before-after__image-wrap before-after__image-wrap--after">
            <span class="before-after__label before-after__label--after">After</span>
            <img
              src={pair.after}
              alt={`${name} project ${i + 1} - after`}
              class="before-after__img"
              loading="lazy"
              width="600"
              height="450"
            />
          </div>
        </div>
      ))}
    </div>

    {showcase && (
      <div class="before-after__showcase animate-fade-up">
        <img
          src={showcase}
          alt={`${name} featured ${category.toLowerCase()} project`}
          class="before-after__showcase-img"
          loading="lazy"
          width="1200"
          height="600"
        />
      </div>
    )}
  </div>
</section>

<style>
  .before-after__header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .before-after__title {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    color: inherit;
    margin: 0 0 0.5rem;
  }

  .before-after__subtitle {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.1rem);
    color: inherit; opacity: 0.7;
    margin: 0;
  }

  .before-after__pairs {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .before-after__pair {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .before-after__image-wrap {
    position: relative;
    border-radius: var(--radius-card);
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .before-after__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .before-after__label {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius);
    z-index: 2;
  }

  .before-after__label--before {
    background: var(--color-text);
    color: var(--color-text-on-dark);
  }

  .before-after__label--after {
    background: var(--color-primary);
    color: var(--color-text-on-dark);
  }

  .before-after__showcase {
    margin-top: 2.5rem;
    border-radius: var(--radius-card);
    overflow: hidden;
  }

  .before-after__showcase-img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 2 / 1;
    object-fit: cover;
  }

  @media (min-width: 600px) {
    .before-after__pair {
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
    }
  }

  @media (min-width: 768px) {
    .before-after__pairs {
      gap: 3rem;
    }
  }
</style>
