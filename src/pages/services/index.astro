---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteConfig } from "../../lib/site-config";
import { getSeoForPage } from "../../lib/seo";
import StickyMinimal from "../../../components/nav/StickyMinimal.astro";
import MultiColumn from "../../../components/footer/MultiColumn.astro";

const biz = siteConfig.business;
const services = siteConfig.content.services;
const seo = getSeoForPage("services");
---

<BaseLayout
  title={seo.title || `Our Services | ${biz.name}`}
  description={seo.description || `Professional ${biz.category.toLowerCase()} services in ${biz.city}, ${biz.state}. Call ${biz.phone} for a free estimate.`}
>
  <StickyMinimal slot="nav" />

  <section class="page-hero">
    <div class="container">
      <h1 class="animate-fade-up">Our Services</h1>
      <p class="hero-sub animate-fade-up">Professional {biz.category.toLowerCase()} solutions for every need</p>
    </div>
  </section>

  <section class="section-padding section-light">
    <div class="container">
      <div class="services-list animate-stagger">
        {services.map((s, i) => (
          <a href={`/services/${s.slug}`} class="service-row">
            {siteConfig.images.services?.[s.slug] && (
              <div class="service-image-wrap">
                <img src={siteConfig.images.services[s.slug]} alt={s.name} loading="lazy" class="service-image" />
              </div>
            )}
            <div class="service-info">
              <h2>{s.name}</h2>
              <p>{s.shortDescription}</p>
              <span class="service-link">Learn More →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <MultiColumn slot="footer" />
</BaseLayout>

<style>
  .page-hero {
    padding: 8rem 0 3rem;
    background: var(--color-background-alt);
    color: var(--color-text-on-dark);
  }
  .page-hero h1 { margin-bottom: 0.5rem; }
  .hero-sub { color: rgba(255,255,255,0.65); font-size: 1.1rem; }

  .services-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .service-row {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 2rem;
    align-items: center;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .service-row:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.06);
  }
  .service-image-wrap { border-radius: var(--radius); overflow: hidden; }
  .service-image { width: 100%; aspect-ratio: 3/2; object-fit: cover; }
  .service-info h2 { font-size: 1.3rem; color: var(--color-text); margin-bottom: 0.4rem; }
  .service-info p { font-size: 0.92rem; color: var(--color-text-light); line-height: 1.65; margin-bottom: 0.5rem; }
  .service-link { font-size: 0.88rem; font-weight: 600; color: var(--color-primary); }

  @media (max-width: 768px) {
    .service-row { grid-template-columns: 1fr; }
    .service-image { aspect-ratio: 16/9; }
  }
</style>
