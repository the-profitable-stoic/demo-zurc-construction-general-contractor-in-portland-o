---
import { siteConfig, getVariant, hasEffect } from "../../lib/site-config";

const biz = siteConfig.business;
const { ctaHeadline, ctaSubline } = siteConfig.content.homepage;
const services = (siteConfig.content.services || []).slice(0, 6);
const variant = getVariant("footer");
const phoneHref = `tel:${biz.phone.replace(/[^+\d]/g, "")}`;
const useGrain = hasEffect("grain");
const isMinimal = variant === "minimal";
const currentYear = new Date().getFullYear();

const navLinks = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about" },
  { label: "Reviews", href: "/reviews" },
  { label: "Contact", href: "/contact" },
];
---

<footer class="footer-cta" role="contentinfo" aria-label="Site footer">
  {/* CTA Banner Section */}
  <section
    class:list={[
      "footer-cta__banner",
      { "footer-cta__banner--minimal": isMinimal },
      { "effect-grain": useGrain },
    ]}
    aria-label="Call to action"
  >
    <div class="footer-cta__banner-inner animate-fade-up">
      <h2 class="footer-cta__headline">{ctaHeadline}</h2>
      {!isMinimal && <p class="footer-cta__subline">{ctaSubline}</p>}
      <div class="footer-cta__banner-actions">
        <a href={phoneHref} class="footer-cta__phone" aria-label={`Call ${biz.name}`}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span>{biz.phone}</span>
        </a>
        <a href="/contact" class="btn-primary footer-cta__btn">Get Free Estimate</a>
      </div>
    </div>
  </section>

  {/* Footer Content */}
  <div class:list={["footer-cta__body", { "footer-cta__body--minimal": isMinimal }]}>
    <div class="footer-cta__body-inner">
      {isMinimal ? (
        <div class="footer-cta__compact">
          <a href="/" class="footer-cta__brand" aria-label={`${biz.name} home`}>{biz.name}</a>
          <nav class="footer-cta__compact-links" aria-label="Footer navigation">
            {navLinks.map((link) => (
              <a href={link.href} class="footer-cta__compact-link">{link.label}</a>
            ))}
          </nav>
          <p class="footer-cta__copyright">&copy; {currentYear} {biz.name}. All rights reserved.</p>
        </div>
      ) : (
        <div class="footer-cta__columns animate-fade-up">
          <div class="footer-cta__col footer-cta__col--brand">
            <a href="/" class="footer-cta__brand" aria-label={`${biz.name} home`}>{biz.name}</a>
            <p class="footer-cta__tagline">
              Trusted {biz.category.toLowerCase()} serving {biz.city}, {biz.state} and surrounding areas.
            </p>
          </div>
          <div class="footer-cta__col">
            <h3 class="footer-cta__col-heading">Navigation</h3>
            <ul class="footer-cta__col-links" role="list">
              {navLinks.map((link) => (
                <li><a href={link.href}>{link.label}</a></li>
              ))}
            </ul>
          </div>
          <div class="footer-cta__col">
            <h3 class="footer-cta__col-heading">Services</h3>
            <ul class="footer-cta__col-links" role="list">
              {services.map((s: any) => (
                <li><a href={`/services/${s.slug}/`}>{s.name}</a></li>
              ))}
            </ul>
          </div>
          <div class="footer-cta__col">
            <h3 class="footer-cta__col-heading">Contact</h3>
            <ul class="footer-cta__col-links" role="list">
              <li><a href={phoneHref}>{biz.phone}</a></li>
              <li><span>{biz.city}, {biz.state}</span></li>
            </ul>
          </div>
        </div>
      )}

      {!isMinimal && (
        <div class="footer-cta__bottom">
          <p class="footer-cta__copyright">&copy; {currentYear} {biz.name}. All rights reserved.</p>
        </div>
      )}
    </div>
  </div>
</footer>

<style>
  /* ========== CTA Banner ========== */
  .footer-cta__banner {
    background: var(--color-primary);
    color: var(--color-text-on-dark);
    padding: 4rem 2rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .footer-cta__banner--minimal {
    padding: 2.5rem 2rem;
  }

  .footer-cta__banner-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .footer-cta__headline {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    line-height: 1.15;
    margin: 0 0 0.75rem;
    color: var(--color-text-on-dark);
  }

  .footer-cta__banner--minimal .footer-cta__headline {
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    margin-bottom: 0;
  }

  .footer-cta__subline {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.15rem);
    line-height: 1.7;
    opacity: 0.88;
    margin: 0 0 2rem;
  }

  .footer-cta__banner-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .footer-cta__banner--minimal .footer-cta__banner-actions {
    flex-direction: row;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1.25rem;
  }

  .footer-cta__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 700;
    color: var(--color-text-on-dark);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .footer-cta__banner--minimal .footer-cta__phone {
    font-size: 1.1rem;
  }

  .footer-cta__phone:hover {
    opacity: 0.85;
  }

  .footer-cta__btn {
    padding: 0.9rem 2.25rem;
    font-size: 1rem;
    font-weight: 700;
    border-radius: var(--radius-button);
    text-decoration: none;
  }

  /* ========== Footer Body ========== */
  .footer-cta__body {
    background: var(--color-primary-dark);
    color: var(--color-text-on-dark);
    padding: 3.5rem 2rem 0;
  }

  .footer-cta__body--minimal {
    padding: 2rem 2rem 0;
  }

  .footer-cta__body-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Compact (minimal variant) */
  .footer-cta__compact {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    padding-bottom: 2rem;
    text-align: center;
  }

  .footer-cta__compact-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem 1.5rem;
  }

  .footer-cta__compact-link {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-cta__compact-link:hover {
    color: var(--color-text-on-dark);
  }

  /* Multi-column (default variant) */
  .footer-cta__columns {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-cta__brand {
    display: inline-block;
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.4rem;
    color: var(--color-text-on-dark);
    text-decoration: none;
    margin-bottom: 0.75rem;
  }

  .footer-cta__tagline {
    font-family: var(--font-body);
    font-size: 0.925rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.7;
    margin: 0;
  }

  .footer-cta__col-heading {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.45);
    margin: 0 0 1rem;
  }

  .footer-cta__col-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-cta__col-links a {
    font-family: var(--font-body);
    font-size: 0.925rem;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-cta__col-links a:hover {
    color: var(--color-text-on-dark);
  }

  .footer-cta__col-links span {
    font-family: var(--font-body);
    font-size: 0.925rem;
    color: rgba(255, 255, 255, 0.55);
  }

  /* Bottom bar */
  .footer-cta__bottom {
    padding: 1.75rem 0;
    text-align: center;
  }

  .footer-cta__copyright {
    font-family: var(--font-body);
    font-size: 0.825rem;
    color: rgba(255, 255, 255, 0.4);
    margin: 0;
  }

  /* ========== Responsive ========== */
  @media (min-width: 640px) {
    .footer-cta__columns {
      grid-template-columns: 1fr 1fr;
    }

    .footer-cta__banner-actions {
      flex-direction: row;
      justify-content: center;
    }
  }

  @media (min-width: 1024px) {
    .footer-cta__banner {
      padding: 5rem 2rem;
    }

    .footer-cta__columns {
      grid-template-columns: 1.6fr 1fr 1fr 1fr;
      gap: 3rem;
    }

    .footer-cta__body {
      padding-top: 4rem;
    }
  }
</style>
