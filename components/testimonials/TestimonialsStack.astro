---
import { siteConfig, getVariant, hasEffect } from "../../lib/site-config";

const reviews = siteConfig.content.reviews;
const variant = getVariant("testimonials");
const isFlat = variant === "flat";
const stackedReviews = reviews.slice(0, 4);
---

<section class="testimonials-stack section-padding" aria-labelledby="stack-testimonials-heading">
  <div class="testimonials-stack__container">
    <div class="testimonials-stack__header animate-fade-up">
      <h2 id="stack-testimonials-heading" class="testimonials-stack__title">What Our Clients Say</h2>
    </div>

    <div class:list={["testimonials-stack__deck", "animate-scale-in", { "testimonials-stack__deck--flat": isFlat }]} role="list" aria-label="Stacked client testimonials">
      {stackedReviews.map((review, i) => {
        const initial = review.name.charAt(0).toUpperCase();
        return (
          <article
            class={`testimonials-stack__card testimonials-stack__card--${i}`}
            role="listitem"
            aria-label={`Review by ${review.name}`}
            style={`--card-index: ${i}; --card-total: ${stackedReviews.length};`}
          >
            <div class="testimonials-stack__stars" role="img" aria-label={`${review.rating} out of 5 stars`}>
              {Array.from({ length: 5 }).map((_, s) => (
                <svg
                  class={`testimonials-stack__star ${s < review.rating ? "testimonials-stack__star--filled" : ""}`}
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill={s < review.rating ? "currentColor" : "none"}
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                </svg>
              ))}
            </div>
            <blockquote class="testimonials-stack__text">
              <p>{review.text}</p>
            </blockquote>
            <footer class="testimonials-stack__footer">
              <div class="testimonials-stack__avatar" aria-hidden="true">
                <span>{initial}</span>
              </div>
              <div class="testimonials-stack__meta">
                <cite class="testimonials-stack__name">{review.name}</cite>
                {review.service && (
                  <span class="testimonials-stack__service">{review.service}</span>
                )}
              </div>
            </footer>
          </article>
        );
      })}
    </div>

    <div class="testimonials-stack__dots" aria-hidden="true">
      {stackedReviews.map((_, i) => (
        <span class={`testimonials-stack__dot ${i === 0 ? "testimonials-stack__dot--active" : ""}`} />
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials-stack {
    background: var(--color-background);
  }

  .testimonials-stack__container {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .testimonials-stack__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .testimonials-stack__title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    color: var(--color-text);
    margin: 0;
    line-height: 1.2;
  }

  /* Deck container */
  .testimonials-stack__deck {
    position: relative;
    min-height: 340px;
    display: flex;
    justify-content: center;
  }

  /* Card base styling */
  .testimonials-stack__card {
    position: absolute;
    width: 100%;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: transform 0.4s ease, opacity 0.4s ease;
  }

  /* Default variant: fanned/rotated cards */
  .testimonials-stack__card--0 {
    z-index: 4;
    transform: translateY(0) rotate(0deg) scale(1);
    opacity: 1;
    box-shadow: 0 4px 24px rgba(0, 0, 0, calc(var(--shadow-intensity, 0.1)));
  }

  .testimonials-stack__card--1 {
    z-index: 3;
    transform: translateY(12px) rotate(2deg) scale(0.96);
    opacity: 0.7;
  }

  .testimonials-stack__card--2 {
    z-index: 2;
    transform: translateY(24px) rotate(-1.5deg) scale(0.92);
    opacity: 0.5;
  }

  .testimonials-stack__card--3 {
    z-index: 1;
    transform: translateY(36px) rotate(1deg) scale(0.88);
    opacity: 0.35;
  }

  /* Flat variant: neat vertical stack with subtle peek */
  .testimonials-stack__deck--flat .testimonials-stack__card--0 {
    transform: translateY(0) scale(1);
    opacity: 1;
  }

  .testimonials-stack__deck--flat .testimonials-stack__card--1 {
    transform: translateY(8px) scale(0.98);
    opacity: 0.6;
  }

  .testimonials-stack__deck--flat .testimonials-stack__card--2 {
    transform: translateY(16px) scale(0.96);
    opacity: 0.35;
  }

  .testimonials-stack__deck--flat .testimonials-stack__card--3 {
    transform: translateY(24px) scale(0.94);
    opacity: 0.2;
  }

  .testimonials-stack__stars {
    display: flex;
    gap: 0.15rem;
  }

  .testimonials-stack__star--filled {
    color: var(--color-accent, #f59e0b);
  }

  .testimonials-stack__star:not(.testimonials-stack__star--filled) {
    color: var(--color-border);
  }

  .testimonials-stack__text {
    margin: 0;
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text);
  }

  .testimonials-stack__text p {
    margin: 0;
  }

  .testimonials-stack__footer {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .testimonials-stack__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-primary);
    color: var(--color-text-on-dark, #fff);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .testimonials-stack__meta {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .testimonials-stack__name {
    font-family: var(--font-heading);
    font-style: normal;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-text);
  }

  .testimonials-stack__service {
    font-size: 0.8rem;
    color: var(--color-text-light);
  }

  /* Navigation dots */
  .testimonials-stack__dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 3.5rem;
  }

  .testimonials-stack__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-border);
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .testimonials-stack__dot--active {
    background: var(--color-primary);
    transform: scale(1.25);
  }

  @media (max-width: 640px) {
    .testimonials-stack__container {
      max-width: 100%;
    }

    .testimonials-stack__card {
      padding: 1.5rem;
    }

    .testimonials-stack__deck {
      min-height: 300px;
    }
  }
</style>
