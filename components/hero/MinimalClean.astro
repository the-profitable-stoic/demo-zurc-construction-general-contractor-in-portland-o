---
import { siteConfig } from '../../lib/site-config';

const { business, content } = siteConfig;
const { homepage, companyInfo } = content;
const yearsDisplay = `${companyInfo.yearsInBusiness}+`;
---

<section class="minimal-clean-hero" aria-label="Hero">
  <div class="container mch__container">
    <div class="mch__content">
      {/* Category badge */}
      <span class="mch__badge animate-fade-in">
        <span class="mch__badge-dot" aria-hidden="true"></span>
        {business.category}
      </span>

      {/* Headline */}
      <h1 class="mch__headline animate-fade-up">{homepage.heroHeadline}</h1>

      {/* Subline */}
      <p class="mch__subline animate-fade-up">{homepage.heroSubline}</p>

      {/* Single CTA */}
      <div class="mch__actions animate-fade-up">
        <a href="/contact" class="btn-primary">Get Started Today</a>
      </div>

      {/* Location line */}
      <p class="mch__location animate-fade-in">
        Serving {business.city}, {business.state} and surrounding areas
      </p>
    </div>

    {/* Decorative years element */}
    <div class="mch__deco animate-fade-in" aria-hidden="true">
      <span class="mch__deco-number">{yearsDisplay}</span>
      <span class="mch__deco-label">Years of<br />Excellence</span>
    </div>
  </div>
</section>

<style>
  .minimal-clean-hero {
    background: var(--color-background);
    padding: clamp(4rem, 10vw, 8rem) 0;
    overflow: hidden;
    position: relative;
    min-height: min(85vh, 680px);
    display: flex;
    align-items: center;
  }

  /* Subtle top border accent */
  .minimal-clean-hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--color-primary) 0%, transparent 60%);
  }

  .mch__container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
  }

  /* Content - left side */
  .mch__content {
    max-width: 38rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }

  /* Badge */
  .mch__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-primary);
    background: var(--color-primary-light);
    padding: 0.5rem 1rem;
    border-radius: var(--radius-button);
  }

  .mch__badge-dot {
    width: 6px;
    height: 6px;
    background: var(--color-primary);
    border-radius: 50%;
    flex-shrink: 0;
    animation: dotPulse 2s ease-in-out infinite;
  }

  @keyframes dotPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* Headline */
  .mch__headline {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: clamp(2.25rem, 6vw, 4.25rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin: 0;
  }

  /* Subline */
  .mch__subline {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.8vw, 1.1875rem);
    line-height: 1.7;
    color: var(--color-text-light);
    margin: 0;
    max-width: 32rem;
  }

  /* Actions */
  .mch__actions {
    margin-top: 0.5rem;
  }

  /* Location */
  .mch__location {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--color-text-light);
    margin: 0;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
    letter-spacing: 0.02em;
  }

  /* Decorative years element - hidden on mobile */
  .mch__deco {
    display: none;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
    position: relative;
  }

  .mch__deco-number {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: clamp(6rem, 12vw, 11rem);
    line-height: 0.85;
    letter-spacing: -0.04em;
    color: transparent;
    -webkit-text-stroke: 2px var(--color-primary);
    opacity: 0.2;
    user-select: none;
  }

  .mch__deco-label {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-light);
    text-align: center;
    line-height: 1.5;
  }

  /* Decorative vertical line */
  .mch__deco::before {
    content: '';
    position: absolute;
    top: -2rem;
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    height: 2rem;
    background: var(--color-border);
  }

  @media (min-width: 768px) {
    .mch__deco {
      display: flex;
    }
  }

  @media (min-width: 1024px) {
    .mch__content {
      gap: 1.75rem;
    }

    .mch__deco-number {
      -webkit-text-stroke-width: 3px;
      opacity: 0.15;
    }
  }

  @media (min-width: 1280px) {
    .mch__container {
      gap: 4rem;
    }
  }
</style>
