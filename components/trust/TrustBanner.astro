---
import { siteConfig, getVariant, hasEffect } from "../../lib/site-config";

const info = siteConfig.content.companyInfo;
const biz = siteConfig.business;
const variant = getVariant("trust");
const isDark = variant !== "light";

const stats = [
  { value: info.yearsInBusiness, suffix: "+", label: "Years in Business" },
  { value: info.projectsCompleted, suffix: "", label: "Projects Completed" },
  { value: info.satisfaction, suffix: "", label: "Client Satisfaction" },
  { value: info.teamSize, suffix: "", label: "Team Members" },
];
---

<section
  class:list={["trust-banner", "section-padding", { "trust-banner--dark": isDark, "trust-banner--light": !isDark }]}
  aria-labelledby="trust-banner-heading"
>
  <div class="trust-banner__container">
    <p class="trust-banner__tagline animate-fade-up" id="trust-banner-heading">
      Trusted by homeowners across {biz.city}
    </p>

    <div class="trust-banner__grid animate-stagger" role="list">
      {stats.map((stat, i) => (
        <div
          class:list={["trust-banner__stat", "animate-fade-up", { "trust-banner__stat--bordered": !isDark }]}
          role="listitem"
          style={`--stagger-index: ${i}`}
        >
          <span class:list={["trust-banner__number", { "effect-text-glow": isDark }]}>
            <span class="stat-counter" style={`--stat-target: ${parseInt(String(stat.value))}`}></span>{stat.suffix}
          </span>
          <span class="trust-banner__label">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Dark variant (default) */
  .trust-banner--dark {
    background: var(--color-primary-dark, var(--color-primary));
    color: var(--color-text-on-dark, #fff);
  }

  /* Light variant */
  .trust-banner--light {
    background: var(--color-background-alt, var(--color-background));
    color: var(--color-text);
  }

  .trust-banner__container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1rem;
    text-align: center;
  }

  .trust-banner__tagline {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.25rem);
    margin: 0 0 2.5rem;
    opacity: 0.85;
    letter-spacing: 0.02em;
  }

  .trust-banner--dark .trust-banner__tagline {
    color: var(--color-text-on-dark, #fff);
    opacity: 0.8;
  }

  .trust-banner--light .trust-banner__tagline {
    color: var(--color-text-light);
  }

  .trust-banner__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .trust-banner__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1.5rem 1rem;
  }

  /* Light variant bordered cards */
  .trust-banner__stat--bordered {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
  }

  .trust-banner__number {
    font-family: var(--font-heading);
    font-size: clamp(2.25rem, 4.5vw, 3.5rem);
    font-weight: 700;
    line-height: 1;
  }

  .trust-banner--dark .trust-banner__number {
    color: var(--color-text-on-dark, #fff);
  }

  .trust-banner--light .trust-banner__number {
    color: var(--color-primary);
  }

  .trust-banner__label {
    font-family: var(--font-body);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.75;
  }

  .trust-banner--dark .trust-banner__label {
    color: var(--color-text-on-dark, #fff);
  }

  .trust-banner--light .trust-banner__label {
    color: var(--color-text-light);
  }

  @media (max-width: 768px) {
    .trust-banner__grid {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .trust-banner__grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .trust-banner__stat {
      padding: 1rem;
    }
  }
</style>
