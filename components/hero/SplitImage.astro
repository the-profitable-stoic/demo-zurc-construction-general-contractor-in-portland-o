---
import { siteConfig } from "../../lib/site-config";

const { heroHeadline, heroSubline } = siteConfig.content.homepage;
const biz = siteConfig.business;
const heroImage = siteConfig.images.hero;
const info = siteConfig.content.companyInfo;
---

<section class="hero-split" aria-label="Hero">
  <div class="hero-text-side">
    <div class="hero-text-inner">
      <div class="hero-badge animate-fade-in">Trusted {biz.category} Contractor</div>
      <h1 class="hero-headline animate-fade-up">{heroHeadline}</h1>
      <p class="hero-subline animate-fade-up">{heroSubline}</p>

      <div class="hero-actions animate-fade-up">
        <a href="/contact" class="btn-primary hero-cta">
          Get a Free Estimate
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
        </a>
        <a href={`tel:${biz.phone.replace(/[^+\d]/g, "")}`} class="btn-secondary hero-call">Call {biz.phone}</a>
      </div>

      <div class="hero-trust animate-fade-up">
        <div class="trust-item">
          <strong>{info.yearsInBusiness}+</strong> years in business
        </div>
        <div class="trust-divider">·</div>
        <div class="trust-item">
          <strong>{info.projectsCompleted}</strong> projects
        </div>
        <div class="trust-divider">·</div>
        <div class="trust-item">
          <strong>{info.satisfaction}</strong> satisfaction
        </div>
      </div>
    </div>
  </div>

  <div class="hero-image-side animate-scale-in">
    {heroImage && (
      <img src={heroImage} alt={`${biz.category} services in ${biz.city}, ${biz.state}`} class="hero-image" loading="eager" />
    )}
    <div class="image-accent"></div>
  </div>
</section>

<style>
  .hero-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 92vh;
    overflow: hidden;
  }
  .hero-text-side {
    display: flex;
    align-items: center;
    background: var(--color-background);
    padding: 2rem;
  }
  .hero-text-inner {
    max-width: 560px;
    margin-left: auto;
    padding: 4rem 3rem 4rem 0;
  }
  .hero-badge {
    display: inline-block;
    padding: 0.4rem 1rem;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
    background: var(--color-primary-light);
    border-radius: 100px;
    margin-bottom: 1.5rem;
  }
  .hero-headline {
    font-size: clamp(2.4rem, 4vw, 3.5rem);
    color: var(--color-text);
    line-height: 1.1;
    letter-spacing: -0.025em;
    margin-bottom: 1.25rem;
  }
  .hero-subline {
    font-size: 1.1rem;
    color: var(--color-text-light);
    line-height: 1.7;
    margin-bottom: 2rem;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .hero-cta { padding: 0.95rem 1.8rem; }
  .hero-call { padding: 0.95rem 1.8rem; }

  .hero-trust {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.88rem;
    color: var(--color-text-light);
  }
  .trust-item strong {
    color: var(--color-text);
    font-weight: 700;
  }
  .trust-divider { color: var(--color-border); }

  .hero-image-side {
    position: relative;
    overflow: hidden;
  }
  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .image-accent {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 30%;
    background: linear-gradient(to top, var(--color-primary), transparent);
    opacity: 0.15;
    pointer-events: none;
  }

  @media (max-width: 1023px) {
    .hero-split {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .hero-image-side {
      order: -1;
      height: 50vh;
      min-height: 320px;
    }
    .hero-text-side { padding: 0 1.5rem; }
    .hero-text-inner {
      padding: 3rem 0;
      margin: 0 auto;
      max-width: 100%;
    }
  }

  @media (max-width: 640px) {
    .hero-image-side { height: 40vh; min-height: 260px; }
    .hero-actions { flex-direction: column; }
    .hero-cta, .hero-call { width: 100%; justify-content: center; }
    .hero-trust { flex-direction: column; gap: 0.35rem; }
    .trust-divider { display: none; }
  }
</style>
