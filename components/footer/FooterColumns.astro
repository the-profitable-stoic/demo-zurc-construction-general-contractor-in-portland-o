---
import { siteConfig, getVariant, hasEffect } from "../../lib/site-config";

const biz = siteConfig.business;
const services = (siteConfig.content.services || []).slice(0, 6);
const serviceAreas = (siteConfig.content.serviceAreas || []).slice(0, 6);
const variant = getVariant("footer");
const isCompact = variant === "compact";
const currentYear = new Date().getFullYear();
const phoneHref = `tel:${biz.phone.replace(/[^+\d]/g, "")}`;

const socialLinks = [
  { label: "Facebook", href: "#", icon: "M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z" },
  { label: "Instagram", href: "#", icon: "M16 4H8a4 4 0 00-4 4v8a4 4 0 004 4h8a4 4 0 004-4V8a4 4 0 00-4-4zm-4 11a3 3 0 110-6 3 3 0 010 6zm4.5-7.5a1 1 0 110-2 1 1 0 010 2z" },
];
---

<footer class:list={["footer-cols", { "footer-cols--compact": isCompact }]} role="contentinfo" aria-label="Site footer">
  <div class="footer-cols__inner">
    <div class="footer-cols__grid animate-fade-up">
      {/* Column 1: Company Info */}
      <div class="footer-cols__col footer-cols__col--brand">
        <a href="/" class="footer-cols__brand" aria-label={`${biz.name} home`}>
          {biz.name}
        </a>
        <p class="footer-cols__desc">
          Professional {biz.category.toLowerCase()} serving {biz.city}, {biz.state} and the surrounding communities. Quality craftsmanship you can trust.
        </p>
        <a href={phoneHref} class="footer-cols__phone" aria-label={`Call ${biz.name}`}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {biz.phone}
        </a>
      </div>

      {/* Column 2: Services */}
      <div class="footer-cols__col">
        <h3 class="footer-cols__heading">Services</h3>
        <ul class="footer-cols__links" role="list">
          {services.map((s: any) => (
            <li><a href={`/services/${s.slug}/`}>{s.name}</a></li>
          ))}
        </ul>
      </div>

      {/* Column 3: Service Areas */}
      <div class="footer-cols__col">
        <h3 class="footer-cols__heading">Service Areas</h3>
        <ul class="footer-cols__links" role="list">
          {serviceAreas.map((area: any) => (
            <li><a href={`/service-areas/${area.slug}/`}>{area.city}</a></li>
          ))}
        </ul>
      </div>

      {/* Column 4: Contact (hidden in compact) */}
      {!isCompact && (
        <div class="footer-cols__col">
          <h3 class="footer-cols__heading">Contact</h3>
          <ul class="footer-cols__links" role="list">
            <li>
              <a href={phoneHref}>{biz.phone}</a>
            </li>
            <li>
              <span class="footer-cols__info">{biz.city}, {biz.state}</span>
            </li>
          </ul>
          <div class="footer-cols__social" aria-label="Social media links">
            {socialLinks.map((s) => (
              <a href={s.href} class="footer-cols__social-link" aria-label={s.label} rel="noopener noreferrer">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={s.icon}/></svg>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>

    {/* Bottom bar */}
    <div class="footer-cols__bottom">
      <p class="footer-cols__copyright">
        &copy; {currentYear} {biz.name}. All rights reserved.
      </p>
      <span class="footer-cols__powered">Powered by modern web technology</span>
    </div>
  </div>
</footer>

<style>
  .footer-cols {
    background: var(--color-primary-dark);
    color: var(--color-text-on-dark);
    padding: 4rem 0 0;
  }

  .footer-cols--compact {
    padding: 3rem 0 0;
  }

  .footer-cols__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ========== Grid ========== */
  .footer-cols__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-bottom: 3rem;
  }

  .footer-cols__col--brand {
    max-width: 340px;
  }

  .footer-cols__brand {
    display: inline-block;
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.4rem;
    color: var(--color-text-on-dark);
    text-decoration: none;
    margin-bottom: 0.85rem;
    line-height: 1.2;
  }

  .footer-cols__desc {
    font-family: var(--font-body);
    font-size: 0.925rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.55);
    margin: 0 0 1.25rem;
  }

  .footer-cols__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-cols__phone:hover {
    color: var(--color-primary-light);
  }

  /* ========== Column headings and links ========== */
  .footer-cols__heading {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.45);
    margin: 0 0 1.15rem;
  }

  .footer-cols__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .footer-cols__links a {
    font-family: var(--font-body);
    font-size: 0.925rem;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-cols__links a:hover {
    color: var(--color-text-on-dark);
  }

  .footer-cols__info {
    font-family: var(--font-body);
    font-size: 0.925rem;
    color: rgba(255, 255, 255, 0.55);
  }

  /* ========== Social ========== */
  .footer-cols__social {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .footer-cols__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius);
    color: rgba(255, 255, 255, 0.5);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: color 0.2s ease, background 0.2s ease;
  }

  .footer-cols__social-link:hover {
    color: var(--color-text-on-dark);
    background: rgba(255, 255, 255, 0.12);
  }

  /* ========== Bottom bar ========== */
  .footer-cols__bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1.75rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    text-align: center;
  }

  .footer-cols__copyright {
    font-family: var(--font-body);
    font-size: 0.825rem;
    color: rgba(255, 255, 255, 0.4);
    margin: 0;
  }

  .footer-cols__powered {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.25);
  }

  /* ========== Responsive ========== */
  @media (min-width: 640px) {
    .footer-cols__grid {
      grid-template-columns: 1fr 1fr;
    }

    .footer-cols__bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  @media (min-width: 1024px) {
    .footer-cols {
      padding-top: 5rem;
    }

    .footer-cols__grid {
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
      gap: 3rem;
      padding-bottom: 4rem;
    }

    .footer-cols--compact .footer-cols__grid {
      grid-template-columns: 1.5fr 1fr 1fr;
    }
  }
</style>
