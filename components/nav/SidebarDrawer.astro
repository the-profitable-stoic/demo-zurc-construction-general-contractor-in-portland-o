---
import { siteConfig } from '../../lib/site-config';

const { business } = siteConfig;
const services = siteConfig.content.services;
const serviceAreas = siteConfig.content.serviceAreas;
const phoneHref = `tel:${business.phone.replace(/[^+\d]/g, "")}`;
---

<header class="sidebar-drawer-nav" role="banner">
  <div class="topbar">
    <div class="container topbar__inner">
      <a href="/" class="topbar__logo" aria-label={`${business.name} - Home`}>
        {business.name}
      </a>
      <div class="topbar__actions">
        <a href={phoneHref} class="topbar__phone" aria-label={`Call ${business.phone}`}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
          <span class="topbar__phone-text">{business.phone}</span>
        </a>
        <button
          class="topbar__trigger"
          aria-label="Open navigation"
          aria-expanded="false"
          aria-controls="sidebar-drawer"
          type="button"
        >
          <span class="trigger-bar"></span>
          <span class="trigger-bar"></span>
          <span class="trigger-bar trigger-bar--short"></span>
        </button>
      </div>
    </div>
  </div>

  {/* Overlay backdrop */}
  <div class="drawer-backdrop" id="drawer-backdrop" aria-hidden="true"></div>

  {/* Sidebar drawer */}
  <aside
    class="drawer"
    id="sidebar-drawer"
    aria-hidden="true"
    role="dialog"
    aria-label="Navigation menu"
  >
    <div class="drawer__inner">
      <div class="drawer__header">
        <span class="drawer__brand">{business.name}</span>
        <button class="drawer__close" aria-label="Close navigation" type="button">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>

      <nav class="drawer__nav" aria-label="Main navigation">
        <ul role="list">
          <li class="drawer__link-item" style="--i: 0">
            <a href="/"><span class="drawer__link-label">Home</span></a>
          </li>
          <li class="drawer__link-item" style="--i: 1">
            <a href="/about"><span class="drawer__link-label">About</span></a>
          </li>

          {/* Services expandable section */}
          <li class="drawer__link-item drawer__expandable" style="--i: 2">
            <details class="drawer__details">
              <summary class="drawer__expand-trigger">
                <span class="drawer__link-label">Services</span>
                <svg class="drawer__chevron" width="12" height="8" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              </summary>
              <div class="drawer__sub-menu">
                <a href="/services" class="drawer__sub-link">All Services</a>
                {services.slice(0, 6).map((s) => (
                  <a href={`/services/${s.slug}`} class="drawer__sub-link">{s.name}</a>
                ))}
              </div>
            </details>
          </li>

          {/* Service Areas expandable section */}
          {serviceAreas.length > 0 && (
            <li class="drawer__link-item drawer__expandable" style="--i: 3">
              <details class="drawer__details">
                <summary class="drawer__expand-trigger">
                  <span class="drawer__link-label">Service Areas</span>
                  <svg class="drawer__chevron" width="12" height="8" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </summary>
                <div class="drawer__sub-menu">
                  <a href="/service-areas" class="drawer__sub-link">All Service Areas</a>
                  {serviceAreas.slice(0, 8).map((a) => (
                    <a href={`/service-areas/${a.slug}`} class="drawer__sub-link">{a.city}, {a.state}</a>
                  ))}
                </div>
              </details>
            </li>
          )}

          <li class="drawer__link-item" style="--i: 4">
            <a href="/reviews"><span class="drawer__link-label">Reviews</span></a>
          </li>
          <li class="drawer__link-item" style="--i: 5">
            <a href="/contact"><span class="drawer__link-label">Contact</span></a>
          </li>
        </ul>
      </nav>

      <div class="drawer__footer">
        <a href={phoneHref} class="drawer__phone" aria-label={`Call ${business.phone}`}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
          </svg>
          {business.phone}
        </a>
        <a href="/contact" class="btn-primary drawer__cta">Get Free Quote</a>
        <p class="drawer__tagline">{business.category} in {business.city}, {business.state}</p>
      </div>
    </div>
  </aside>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const trigger = document.querySelector('.topbar__trigger');
    const drawer = document.querySelector('.drawer');
    const backdrop = document.querySelector('.drawer-backdrop');
    const closeBtn = document.querySelector('.drawer__close');
    const drawerLinks = document.querySelectorAll('.drawer__nav a:not(.drawer__sub-link), .drawer__cta');

    function openDrawer() {
      drawer?.setAttribute('aria-hidden', 'false');
      drawer?.classList.add('is-open');
      backdrop?.setAttribute('aria-hidden', 'false');
      backdrop?.classList.add('is-visible');
      trigger?.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    function closeDrawer() {
      drawer?.setAttribute('aria-hidden', 'true');
      drawer?.classList.remove('is-open');
      backdrop?.setAttribute('aria-hidden', 'true');
      backdrop?.classList.remove('is-visible');
      trigger?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    trigger?.addEventListener('click', openDrawer);
    closeBtn?.addEventListener('click', closeDrawer);
    backdrop?.addEventListener('click', closeDrawer);
    drawerLinks.forEach(link => link.addEventListener('click', closeDrawer));

    // Also close on sub-link click
    document.querySelectorAll('.drawer__sub-link').forEach(link => {
      link.addEventListener('click', closeDrawer);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeDrawer();
    });
  });
</script>

<style>
  /* Top bar */
  .topbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-background);
    border-bottom: 1px solid var(--color-border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .topbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0;
    min-height: 64px;
  }

  .topbar__logo {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight, 800);
    font-size: 1.25rem;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: color 0.25s ease;
  }

  .topbar__logo:hover {
    color: var(--color-primary);
  }

  .topbar__actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .topbar__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.15s;
  }

  .topbar__phone:hover {
    color: var(--color-primary);
  }

  .topbar__phone-text {
    display: none;
  }

  /* Hamburger trigger - always visible */
  .topbar__trigger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    align-items: flex-end;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  .trigger-bar {
    display: block;
    width: 28px;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  .trigger-bar--short {
    width: 18px;
  }

  .topbar__trigger:hover .trigger-bar {
    background: var(--color-primary);
  }

  .topbar__trigger:hover .trigger-bar--short {
    width: 28px;
  }

  /* Backdrop overlay */
  .drawer-backdrop {
    position: fixed;
    inset: 0;
    z-index: 998;
    background: rgba(0, 0, 0, 0);
    visibility: hidden;
    transition: background 0.35s ease, visibility 0.35s ease;
  }

  .drawer-backdrop.is-visible {
    background: rgba(0, 0, 0, 0.5);
    visibility: visible;
  }

  /* Drawer */
  .drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    z-index: 999;
    width: min(85vw, 380px);
    background: var(--color-text);
    color: var(--color-text-on-dark, #fff);
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  .drawer.is-open {
    transform: translateX(0);
  }

  .drawer__inner {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    padding: 1.75rem 2rem;
  }

  /* Drawer header */
  .drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 3rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .drawer__brand {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight, 800);
    font-size: 1.125rem;
    color: var(--color-text-on-dark, #fff);
    letter-spacing: -0.01em;
  }

  .drawer__close {
    background: none;
    border: none;
    color: var(--color-text-on-dark, #fff);
    cursor: pointer;
    padding: 0.25rem;
    opacity: 0.6;
    transition: opacity 0.2s ease, transform 0.25s ease;
  }

  .drawer__close:hover {
    opacity: 1;
    transform: rotate(90deg);
  }

  /* Nav links */
  .drawer__nav {
    flex: 1;
  }

  .drawer__nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .drawer__link-item {
    opacity: 0;
    transform: translateX(30px);
  }

  .drawer.is-open .drawer__link-item {
    animation: drawerSlideIn 0.4s ease forwards;
    animation-delay: calc(0.1s + var(--i) * 0.06s);
  }

  .drawer__link-item > a {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    text-decoration: none;
    padding: 0.85rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    transition: padding-left 0.25s ease;
  }

  .drawer__link-item > a:hover {
    padding-left: 0.5rem;
  }

  .drawer__link-label {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight, 800);
    font-size: 1.5rem;
    color: var(--color-text-on-dark, #fff);
    transition: color 0.2s ease;
  }

  .drawer__link-item > a:hover .drawer__link-label {
    color: var(--color-primary);
  }

  /* Expandable sections (Services / Service Areas) */
  .drawer__details {
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .drawer__expand-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 0;
    cursor: pointer;
    list-style: none;
  }

  .drawer__expand-trigger::-webkit-details-marker {
    display: none;
  }

  .drawer__expand-trigger .drawer__link-label {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight, 800);
    font-size: 1.5rem;
    color: var(--color-text-on-dark, #fff);
    transition: color 0.2s ease;
  }

  .drawer__expand-trigger:hover .drawer__link-label {
    color: var(--color-primary);
  }

  .drawer__chevron {
    color: var(--color-text-on-dark, #fff);
    opacity: 0.5;
    transition: transform 0.25s ease, opacity 0.2s;
    flex-shrink: 0;
  }

  .drawer__details[open] .drawer__chevron {
    transform: rotate(180deg);
    opacity: 0.8;
  }

  .drawer__sub-menu {
    padding: 0.25rem 0 0.75rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .drawer__sub-link {
    display: block;
    padding: 0.5rem 0.75rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--color-text-on-dark, #fff);
    opacity: 0.75;
    text-decoration: none;
    border-radius: var(--radius);
    transition: opacity 0.15s, padding-left 0.2s, color 0.15s;
  }

  .drawer__sub-link:hover {
    opacity: 1;
    padding-left: 1.25rem;
    color: var(--color-primary);
  }

  /* Footer */
  .drawer__footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    opacity: 0;
  }

  .drawer.is-open .drawer__footer {
    animation: drawerSlideIn 0.4s ease forwards;
    animation-delay: 0.5s;
  }

  .drawer__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    color: var(--color-text-on-dark, #fff);
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 500;
    opacity: 0.8;
    transition: opacity 0.2s ease;
  }

  .drawer__phone:hover {
    opacity: 1;
  }

  .drawer__cta {
    text-align: center;
    margin-top: 0.5rem;
  }

  .drawer__tagline {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--color-text-on-dark, #fff);
    opacity: 0.4;
    margin: 0.5rem 0 0;
    letter-spacing: 0.03em;
  }

  @keyframes drawerSlideIn {
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* Larger screens - show phone text */
  @media (min-width: 768px) {
    .topbar__inner {
      min-height: 72px;
    }

    .topbar__logo {
      font-size: 1.4rem;
    }

    .topbar__phone-text {
      display: inline;
    }
  }
</style>
