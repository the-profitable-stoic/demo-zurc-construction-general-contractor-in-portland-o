---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../lib/site-config";
import StickyMinimal from "../../components/nav/StickyMinimal.astro";
import MultiColumn from "../../components/footer/MultiColumn.astro";

const biz = siteConfig.business;
const currentYear = new Date().getFullYear();
---

<BaseLayout
  title={`Privacy Policy | ${biz.name}`}
  description={`Privacy Policy for ${biz.name}. Learn how we collect, use, and protect your personal information.`}
>
  <StickyMinimal slot="nav" />

  <section class="page-hero">
    <div class="container">
      <h1 class="animate-fade-up">Privacy Policy</h1>
      <p class="hero-sub">Your privacy matters to us</p>
    </div>
  </section>

  <section class="section-padding">
    <div class="legal-container">
      <p class="last-updated">Last Updated: January 1, {currentYear}</p>

      <p class="intro">
        {biz.name} ("we," "us," or "our") is committed to protecting your privacy. This Privacy Policy explains
        how we collect, use, disclose, and safeguard your information when you visit our website or use our services.
        Please read this policy carefully.
      </p>

      <h2>1. Information We Collect</h2>
      <p>We may collect personal information that you voluntarily provide to us when you:</p>
      <ul>
        <li>Fill out a contact form or request an estimate</li>
        <li>Call or email us directly</li>
        <li>Subscribe to our newsletter or communications</li>
        <li>Interact with our website</li>
      </ul>
      <p>The types of personal information we may collect include:</p>
      <ul>
        <li><strong>Name</strong> (first and last)</li>
        <li><strong>Email address</strong></li>
        <li><strong>Phone number</strong></li>
        <li><strong>Mailing or service address</strong></li>
        <li><strong>Project details</strong> you provide in form submissions</li>
      </ul>

      <h2>2. How We Use Your Information</h2>
      <p>We use the information we collect for the following purposes:</p>
      <ul>
        <li>To provide free estimates and quotes for our services</li>
        <li>To communicate with you about your project or inquiry</li>
        <li>To respond to your questions and requests</li>
        <li>To schedule appointments and service visits</li>
        <li>To send follow-up communications related to our services</li>
        <li>To improve our website and customer experience</li>
        <li>To comply with legal obligations</li>
      </ul>

      <h2>3. SMS/Text Message Consent</h2>
      <p>
        By providing your phone number and checking the consent box on our forms, you agree to receive calls
        and text messages from {biz.name}, including messages sent by autodialer. These communications may
        include appointment reminders, estimate follow-ups, service updates, and promotional offers.
      </p>
      <ul>
        <li><strong>Message and data rates may apply.</strong></li>
        <li><strong>Message frequency varies</strong> based on your interactions with us.</li>
        <li>Reply <strong>STOP</strong> at any time to unsubscribe from text messages.</li>
        <li>Reply <strong>HELP</strong> for assistance.</li>
      </ul>
      <p>
        Consent to receive text messages is not a condition of purchasing any goods or services.
        Your information will not be shared with third parties for their marketing purposes.
      </p>

      <h2>4. Information Sharing</h2>
      <p>
        We do not sell, trade, or rent your personal information to third parties. We may share your
        information in the following limited circumstances:
      </p>
      <ul>
        <li><strong>Service Providers:</strong> We may share information with trusted third-party vendors
          who assist us in operating our website, conducting our business, or serving you (e.g., CRM systems,
          scheduling tools), so long as those parties agree to keep this information confidential.</li>
        <li><strong>Legal Requirements:</strong> We may disclose your information when required by law,
          regulation, or legal process.</li>
        <li><strong>Business Transfers:</strong> In the event of a merger, acquisition, or sale of assets,
          your information may be transferred as part of that transaction.</li>
      </ul>

      <h2>5. Cookies and Tracking</h2>
      <p>
        Our website may use cookies and similar tracking technologies to enhance your browsing experience.
        These may include:
      </p>
      <ul>
        <li><strong>Essential Cookies:</strong> Required for the website to function properly.</li>
        <li><strong>Analytics Cookies:</strong> Help us understand how visitors interact with our website
          (e.g., Google Analytics).</li>
        <li><strong>Advertising Cookies:</strong> Used to deliver relevant advertisements and track
          campaign performance.</li>
      </ul>
      <p>
        You can control cookie preferences through your browser settings. Disabling cookies may affect
        your experience on our website.
      </p>

      <h2>6. Data Security</h2>
      <p>
        We implement reasonable administrative, technical, and physical security measures to protect your
        personal information from unauthorized access, use, or disclosure. However, no method of transmission
        over the Internet or electronic storage is 100% secure, and we cannot guarantee absolute security.
      </p>

      <h2>7. Your Rights</h2>
      <p>You have the right to:</p>
      <ul>
        <li><strong>Opt out</strong> of marketing communications at any time by replying STOP to text
          messages or clicking the unsubscribe link in emails.</li>
        <li><strong>Request access</strong> to the personal information we hold about you.</li>
        <li><strong>Request correction</strong> of any inaccurate personal information.</li>
        <li><strong>Request deletion</strong> of your personal data, subject to legal and contractual
          obligations.</li>
      </ul>
      <p>
        To exercise any of these rights, please contact us using the information provided below.
      </p>

      <h2>8. Contact Information</h2>
      <p>If you have questions or concerns about this Privacy Policy, please contact us:</p>
      <div class="contact-block">
        <p><strong>{biz.name}</strong></p>
        <p>Phone: <a href={`tel:${biz.phone}`}>{biz.phone}</a></p>
        {biz.email && <p>Email: <a href={`mailto:${biz.email}`}>{biz.email}</a></p>}
      </div>

      <h2>9. Changes to This Policy</h2>
      <p>
        We reserve the right to update or modify this Privacy Policy at any time. Changes will be posted
        on this page with an updated "Last Updated" date. Your continued use of our website after any
        changes constitutes your acceptance of the revised policy. We encourage you to review this page
        periodically.
      </p>
    </div>
  </section>

  <MultiColumn slot="footer" />
</BaseLayout>

<style>
  .page-hero {
    padding: 8rem 0 3rem;
    background: var(--color-background-alt);
    color: var(--color-text-on-dark);
  }
  .page-hero h1 { margin-bottom: 0.5rem; }
  .hero-sub { color: rgba(255,255,255,0.65); font-size: 1.1rem; }

  .legal-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .last-updated {
    font-size: 0.9rem;
    color: var(--color-text-light);
    font-style: italic;
    margin-bottom: 2rem;
  }

  .intro {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--color-text);
    margin-bottom: 2.5rem;
  }

  h2 {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: 1.35rem;
    color: var(--color-text);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--color-border, #e5e7eb);
  }

  p {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-light);
    margin-bottom: 1rem;
  }

  ul {
    margin: 0.5rem 0 1.5rem 1.5rem;
    padding: 0;
  }

  li {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-light);
    margin-bottom: 0.4rem;
  }

  .contact-block {
    background: var(--color-surface, #f9fafb);
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: var(--radius-card, 8px);
    padding: 1.5rem;
    margin: 1rem 0 1.5rem;
  }

  .contact-block p { margin-bottom: 0.3rem; }
  .contact-block a { color: var(--color-primary); text-decoration: none; }
  .contact-block a:hover { text-decoration: underline; }

  @media (max-width: 640px) {
    .legal-container { padding: 0 1rem; }
    h2 { font-size: 1.2rem; }
  }
</style>
