---
import { siteConfig } from "../../lib/site-config";

const { heroHeadline, heroSubline } = siteConfig.content.homepage;
const biz = siteConfig.business;
const heroImage = siteConfig.images.hero;
const info = siteConfig.content.companyInfo;
---

<section class="hero-dark" aria-label="Hero">
  {heroImage && <img src={heroImage} alt={`${biz.category} services in ${biz.city}`} class="hero-bg" loading="eager" />}
  <div class="hero-overlay"></div>

  <div class="container hero-content">
    <div class="hero-badge animate-fade-in">{biz.category} Experts</div>
    <h1 class="hero-headline animate-fade-up">{heroHeadline}</h1>
    <p class="hero-subline animate-fade-up">{heroSubline}</p>

    <div class="hero-actions animate-fade-up">
      <a href="/contact" class="btn-primary hero-cta">
        Get Your Free Estimate
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
      </a>
      <a href={`tel:${biz.phone.replace(/[^+\d]/g, "")}`} class="btn-secondary hero-call">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        {biz.phone}
      </a>
    </div>

    <div class="hero-stats animate-fade-up">
      <div class="stat">
        <span class="stat-value">{info.yearsInBusiness}+</span>
        <span class="stat-label">Years Experience</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-value">{info.projectsCompleted}</span>
        <span class="stat-label">Projects Completed</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-value">{info.satisfaction}</span>
        <span class="stat-label">Client Satisfaction</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-dark {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--color-background-alt);
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.55) 0%,
      rgba(0, 0, 0, 0.7) 60%,
      rgba(0, 0, 0, 0.85) 100%
    );
  }
  .hero-content {
    position: relative;
    z-index: 2;
    padding-top: 8rem;
    padding-bottom: 4rem;
    max-width: 800px;
  }
  .hero-badge {
    display: inline-block;
    padding: 0.4rem 1rem;
    font-family: var(--font-heading);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary);
    border: 1px solid var(--color-primary);
    border-radius: 100px;
    margin-bottom: 1.5rem;
  }
  .hero-headline {
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    color: #fff;
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
  }
  .hero-subline {
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.65;
    max-width: 600px;
    margin-bottom: 2.5rem;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 3.5rem;
  }
  .hero-cta {
    padding: 1rem 2rem;
    font-size: 1rem;
  }
  .hero-call {
    border-color: rgba(255, 255, 255, 0.4);
    color: #fff;
  }
  .hero-call:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: #fff;
    color: #fff;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .stat { text-align: center; }
  .stat-value {
    display: block;
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: 1.8rem;
    color: var(--color-primary);
    line-height: 1.2;
  }
  .stat-label {
    display: block;
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 0.25rem;
  }
  .stat-divider {
    width: 1px;
    height: 40px;
    background: rgba(255, 255, 255, 0.15);
  }

  @media (max-width: 768px) {
    .hero-dark { min-height: 100svh; }
    .hero-content { padding-top: 6rem; }
    .hero-stats { gap: 1.25rem; }
    .stat-value { font-size: 1.4rem; }
    .hero-cta { width: 100%; justify-content: center; }
    .hero-call { width: 100%; justify-content: center; }
  }
</style>
