---
import { siteConfig, getVariant, hasEffect } from "../../lib/site-config";

const reviews = siteConfig.content.reviews;
const variant = getVariant("testimonials");
const isDouble = variant === "double";
const glassActive = hasEffect("glass");
---

<section class="testimonials-marquee section-padding" aria-labelledby="marquee-testimonials-heading">
  <div class="testimonials-marquee__container">
    <div class="testimonials-marquee__header animate-fade-up">
      <h2 id="marquee-testimonials-heading" class="testimonials-marquee__title">What Our Clients Say</h2>
    </div>

    <div class="marquee-container" role="region" aria-label="Client testimonials scrolling">
      <div class="marquee-track">
        {[...reviews, ...reviews].map((review, i) => (
          <article
            class:list={["testimonials-marquee__card", { "effect-glass": glassActive }]}
            aria-label={`Review by ${review.name}`}
          >
            <div class="testimonials-marquee__stars" role="img" aria-label={`${review.rating} out of 5 stars`}>
              {Array.from({ length: 5 }).map((_, s) => (
                <svg
                  class={`testimonials-marquee__star ${s < review.rating ? "testimonials-marquee__star--filled" : ""}`}
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill={s < review.rating ? "currentColor" : "none"}
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                </svg>
              ))}
            </div>
            <blockquote class="testimonials-marquee__text">
              <p>{review.text}</p>
            </blockquote>
            <footer class="testimonials-marquee__footer">
              <cite class="testimonials-marquee__name">{review.name}</cite>
              {review.service && (
                <span class="testimonials-marquee__service">{review.service}</span>
              )}
            </footer>
          </article>
        ))}
      </div>
    </div>

    {isDouble && (
      <div class="marquee-container testimonials-marquee__row-reverse" role="region" aria-label="Additional client testimonials scrolling">
        <div class="marquee-track testimonials-marquee__track-reverse">
          {[...reviews, ...reviews].map((review, i) => (
            <article
              class:list={["testimonials-marquee__card", { "effect-glass": glassActive }]}
              aria-label={`Review by ${review.name}`}
            >
              <div class="testimonials-marquee__stars" role="img" aria-label={`${review.rating} out of 5 stars`}>
                {Array.from({ length: 5 }).map((_, s) => (
                  <svg
                    class={`testimonials-marquee__star ${s < review.rating ? "testimonials-marquee__star--filled" : ""}`}
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill={s < review.rating ? "currentColor" : "none"}
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                  </svg>
                ))}
              </div>
              <blockquote class="testimonials-marquee__text">
                <p>{review.text}</p>
              </blockquote>
              <footer class="testimonials-marquee__footer">
                <cite class="testimonials-marquee__name">{review.name}</cite>
                {review.service && (
                  <span class="testimonials-marquee__service">{review.service}</span>
                )}
              </footer>
            </article>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .testimonials-marquee {
    background: var(--color-background-alt);
    overflow: hidden;
  }

  .testimonials-marquee__container {
    max-width: 100%;
  }

  .testimonials-marquee__header {
    text-align: center;
    margin-bottom: 2.5rem;
    padding: 0 1rem;
  }

  .testimonials-marquee__title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    color: var(--color-text);
    margin: 0;
    line-height: 1.2;
  }

  .testimonials-marquee__row-reverse {
    margin-top: 1.5rem;
  }

  .testimonials-marquee__track-reverse {
    animation-direction: reverse;
  }

  .testimonials-marquee__card {
    flex: 0 0 auto;
    width: 320px;
    max-width: 85vw;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .testimonials-marquee__stars {
    display: flex;
    gap: 0.15rem;
  }

  .testimonials-marquee__star--filled {
    color: var(--color-accent, #f59e0b);
  }

  .testimonials-marquee__star:not(.testimonials-marquee__star--filled) {
    color: var(--color-border);
  }

  .testimonials-marquee__text {
    margin: 0;
    font-family: var(--font-body);
    font-size: 0.925rem;
    line-height: 1.6;
    color: var(--color-text);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .testimonials-marquee__text p {
    margin: 0;
  }

  .testimonials-marquee__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-border);
  }

  .testimonials-marquee__name {
    font-family: var(--font-heading);
    font-style: normal;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .testimonials-marquee__service {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-primary);
    background: var(--color-primary-light, color-mix(in srgb, var(--color-primary) 10%, transparent));
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .testimonials-marquee__card {
      width: 280px;
      padding: 1.25rem;
    }
  }
</style>
