---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../lib/site-config";
import { getSeoForPage } from "../lib/seo";
import StickyMinimal from "../../components/nav/StickyMinimal.astro";
import MultiColumn from "../../components/footer/MultiColumn.astro";

const biz = siteConfig.business;
const about = siteConfig.content.homepage;
const info = siteConfig.content.companyInfo;
const aboutImage = siteConfig.images.about;
const seo = getSeoForPage("about");
---

<BaseLayout
  title={seo.title || `About Us | ${biz.name}`}
  description={seo.description || `Learn about ${biz.name}, your trusted ${biz.category.toLowerCase()} contractor in ${biz.city}, ${biz.state}. ${info.yearsInBusiness}+ years of experience.`}
>
  <StickyMinimal slot="nav" />

  <section class="page-hero">
    <div class="container">
      <h1 class="animate-fade-up">About {biz.name}</h1>
      <p class="hero-sub animate-fade-up">{info.yearsInBusiness}+ years serving {biz.city} and surrounding areas</p>
    </div>
  </section>

  <section class="section-padding section-light">
    <div class="container about-layout">
      <div class="about-text animate-fade-up">
        {about.aboutText.map((p) => <p class="body-text">{p}</p>)}
      </div>
      {aboutImage && (
        <div class="about-image-wrap animate-scale-in">
          <img src={aboutImage} alt={`${biz.name} team`} loading="lazy" class="about-img" />
        </div>
      )}
    </div>
  </section>

  <section class="section-padding section-surface">
    <div class="container">
      <div class="stats-grid animate-stagger">
        <div class="stat-block">
          <span class="stat-val">{info.yearsInBusiness}+</span>
          <span class="stat-lbl">Years in Business</span>
        </div>
        <div class="stat-block">
          <span class="stat-val">{info.projectsCompleted}</span>
          <span class="stat-lbl">Projects Completed</span>
        </div>
        <div class="stat-block">
          <span class="stat-val">{info.satisfaction}</span>
          <span class="stat-lbl">Client Satisfaction</span>
        </div>
        <div class="stat-block">
          <span class="stat-val">{info.teamSize}</span>
          <span class="stat-lbl">Team Members</span>
        </div>
      </div>
    </div>
  </section>

  <MultiColumn slot="footer" />
</BaseLayout>

<style>
  .page-hero { padding: 8rem 0 3rem; background: var(--color-background-alt); color: var(--color-text-on-dark); }
  .page-hero h1 { margin-bottom: 0.5rem; }
  .hero-sub { color: rgba(255,255,255,0.65); font-size: 1.1rem; }

  .about-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
  .body-text { font-size: 1.02rem; line-height: 1.85; color: var(--color-text-light); margin-bottom: 1rem; }
  .about-image-wrap { border-radius: var(--radius-card); overflow: hidden; }
  .about-img { width: 100%; aspect-ratio: 4/3; object-fit: cover; }

  .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; text-align: center; }
  .stat-block { padding: 2rem 1rem; }
  .stat-val { display: block; font-family: var(--font-heading); font-weight: var(--font-heading-weight); font-size: 2.2rem; color: var(--color-primary); }
  .stat-lbl { display: block; font-size: 0.82rem; color: var(--color-text-light); text-transform: uppercase; letter-spacing: 0.06em; margin-top: 0.25rem; }

  @media (max-width: 1023px) { .about-layout { grid-template-columns: 1fr; } .about-image-wrap { order: -1; } }
  @media (max-width: 640px) { .stats-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
