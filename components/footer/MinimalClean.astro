---
import { siteConfig } from '../../lib/site-config';

const { name, phone } = siteConfig.business;
const phoneHref = `tel:${phone.replace(/[^+\d]/g, '')}`;
const year = new Date().getFullYear();

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services' },
  { label: 'Gallery', href: '/gallery' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];
---

<footer class="minimal-footer" role="contentinfo">
  <div class="container">
    <div class="minimal-footer__top">
      <div class="minimal-footer__brand">
        <span class="minimal-footer__name">{name}</span>
      </div>
      <nav class="minimal-footer__nav" aria-label="Footer navigation">
        <ul class="minimal-footer__links">
          {navLinks.map((link) => (
            <li class="minimal-footer__link-item">
              <a href={link.href} class="minimal-footer__link">{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>
      <div class="minimal-footer__phone">
        <a href={phoneHref} class="minimal-footer__phone-link">{phone}</a>
      </div>
    </div>
    <div class="minimal-footer__divider"></div>
    <div class="minimal-footer__bottom">
      <p class="minimal-footer__copyright">&copy; {year} {name}. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .minimal-footer {
    background: var(--color-text);
    color: var(--color-text-on-dark);
    padding: 2rem 0 1.5rem;
  }

  .minimal-footer__top {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    text-align: center;
  }

  .minimal-footer__brand {
    flex-shrink: 0;
  }

  .minimal-footer__name {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: 1.15rem;
    color: var(--color-text-on-dark);
  }

  .minimal-footer__nav {
    flex: 1;
  }

  .minimal-footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem 1.5rem;
  }

  .minimal-footer__link {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-text-on-dark);
    text-decoration: none;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }

  .minimal-footer__link:hover {
    opacity: 1;
  }

  .minimal-footer__phone-link {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-on-dark);
    text-decoration: none;
    opacity: 0.9;
    transition: opacity 0.2s ease;
  }

  .minimal-footer__phone-link:hover {
    opacity: 1;
  }

  .minimal-footer__divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
    margin: 1.5rem 0 1rem;
  }

  .minimal-footer__bottom {
    text-align: center;
  }

  .minimal-footer__copyright {
    font-family: var(--font-body);
    font-size: 0.8rem;
    opacity: 0.45;
    margin: 0;
  }

  @media (min-width: 768px) {
    .minimal-footer__top {
      flex-direction: row;
      text-align: left;
    }

    .minimal-footer__links {
      gap: 0.25rem 1.75rem;
    }

    .minimal-footer__phone {
      flex-shrink: 0;
    }
  }
</style>
