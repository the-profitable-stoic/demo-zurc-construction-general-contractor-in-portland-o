---
import { siteConfig } from "../../lib/site-config";

const { heroHeadline, heroSubline } = siteConfig.content.homepage;
const biz = siteConfig.business;
const heroImage = siteConfig.images.hero;
const info = siteConfig.content.companyInfo;
---

<section class="hero-gradient" aria-label="Hero">
  {heroImage && <img src={heroImage} alt={`${biz.category} services in ${biz.city}`} class="hero-bg" loading="eager" />}
  <div class="hero-gradient-overlay"></div>

  <div class="container hero-content">
    <div class="hero-top-bar animate-fade-in">
      <span class="bar-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        {biz.city}, {biz.state}
      </span>
      <span class="bar-divider">|</span>
      <span class="bar-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
        {biz.phone}
      </span>
    </div>

    <h1 class="hero-headline animate-fade-up">{heroHeadline}</h1>
    <p class="hero-subline animate-fade-up">{heroSubline}</p>

    <div class="hero-actions animate-fade-up">
      <a href="/contact" class="btn-primary hero-cta-main">
        Request Free Estimate
      </a>
      <a href="/services" class="hero-cta-link">
        View Our Services
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>

  <div class="hero-bottom">
    <div class="container">
      <div class="hero-stat-bar animate-fade-up">
        <div class="stat-item">
          <span class="stat-num">{info.yearsInBusiness}+</span>
          <span class="stat-text">Years</span>
        </div>
        <div class="stat-item">
          <span class="stat-num">{info.projectsCompleted}</span>
          <span class="stat-text">Projects</span>
        </div>
        <div class="stat-item">
          <span class="stat-num">{info.satisfaction}</span>
          <span class="stat-text">Satisfaction</span>
        </div>
        <div class="stat-item">
          <span class="stat-num">{info.teamSize}</span>
          <span class="stat-text">Team Members</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-gradient {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    background: var(--color-background-alt);
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-gradient-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(0, 0, 0, 0.8) 0%,
      rgba(0, 0, 0, 0.4) 50%,
      color-mix(in srgb, var(--color-primary) 30%, transparent) 100%
    );
  }
  .hero-content {
    position: relative;
    z-index: 2;
    padding-top: 10rem;
    text-align: center;
    max-width: 820px;
    margin: 0 auto;
  }
  .hero-top-bar {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 1.25rem;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.8);
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 100px;
    backdrop-filter: blur(4px);
    margin-bottom: 2rem;
  }
  .bar-item {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  .bar-divider { opacity: 0.3; }

  .hero-headline {
    font-size: clamp(2.6rem, 5.5vw, 4.2rem);
    color: #fff;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
  }
  .hero-subline {
    font-size: clamp(1rem, 1.8vw, 1.2rem);
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.7;
    max-width: 620px;
    margin: 0 auto 2.5rem;
  }
  .hero-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1.5rem;
  }
  .hero-cta-main {
    padding: 1rem 2.5rem;
    font-size: 1rem;
  }
  .hero-cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    transition: color 0.2s;
  }
  .hero-cta-link:hover { color: #fff; }

  .hero-bottom {
    position: relative;
    z-index: 2;
    margin-top: auto;
    padding-bottom: 0;
  }
  .hero-stat-bar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    background: rgba(255, 255, 255, 0.06);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(8px);
  }
  .stat-item {
    text-align: center;
    padding: 1.5rem 1rem;
  }
  .stat-item + .stat-item {
    border-left: 1px solid rgba(255, 255, 255, 0.08);
  }
  .stat-num {
    display: block;
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: 1.6rem;
    color: #fff;
    line-height: 1.2;
  }
  .stat-text {
    display: block;
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.55);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 0.2rem;
  }

  @media (max-width: 768px) {
    .hero-gradient { min-height: 100svh; }
    .hero-content { padding-top: 7rem; }
    .hero-stat-bar { grid-template-columns: repeat(2, 1fr); }
    .stat-item:nth-child(3) { border-left: none; }
    .hero-cta-main { width: 100%; justify-content: center; }
  }
</style>
